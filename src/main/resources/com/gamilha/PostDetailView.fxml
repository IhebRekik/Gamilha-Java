<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controllers.PostDetailController"
            style="-fx-background-color:#13131f;">

    <!-- Header -->
    <top>
        <VBox style="-fx-background-color:#1a1a2e;-fx-border-color:#3a3a5c;-fx-border-width:0 0 1 0;">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <Label text="📋  Détail du Post"
                   style="-fx-font-size:17;-fx-font-weight:bold;-fx-text-fill:#e6edf3;"/>
        </VBox>
    </top>

    <!-- Corps scrollable -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background:transparent;-fx-background-color:transparent;
                           -fx-border-color:transparent;">
            <content>
                <VBox spacing="0">

                    <!-- Image du post -->
                    <ImageView fx:id="postImage"
                               fitWidth="580" fitHeight="230"
                               preserveRatio="false" smooth="true"/>

                    <!-- Méta-infos -->
                    <VBox spacing="6"
                          style="-fx-background-color:#1e1e2e;">
                        <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>

                        <Label fx:id="authorLabel"
                               style="-fx-font-size:13;-fx-text-fill:#c9d1d9;-fx-font-weight:bold;"/>
                        <HBox spacing="24">
                            <Label fx:id="dateLabel"
                                   style="-fx-font-size:12;-fx-text-fill:#8b949e;"/>
                            <Label fx:id="likesLabel"
                                   style="-fx-font-size:12;-fx-text-fill:#ff6b81;-fx-font-weight:bold;"/>
                        </HBox>

                        <Separator/>

                        <TextArea fx:id="contentArea"
                                  wrapText="true" editable="false" prefHeight="100"
                                  style="-fx-background-color:#252535;-fx-text-fill:#e6edf3;
                                         -fx-font-size:13;-fx-border-color:transparent;
                                         -fx-background-radius:8;"/>
                    </VBox>

                    <!-- Section commentaires -->
                    <VBox spacing="10">
                        <padding><Insets top="4" right="20" bottom="20" left="20"/></padding>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <VBox.margin><Insets top="14"/></VBox.margin>
                            <Label text="💬  Commentaires"
                                   style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#e6edf3;"/>
                            <Label fx:id="commentsCountLabel"
                                   style="-fx-text-fill:#8b949e;-fx-font-size:13;"/>
                        </HBox>

                        <VBox fx:id="commentsBox" spacing="8"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
