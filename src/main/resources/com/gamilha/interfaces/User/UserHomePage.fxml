<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gamilha.controllers.UserHomeController"
      VBox.vgrow="ALWAYS"
      maxWidth="Infinity"
      maxHeight="Infinity"
      style="-fx-background-color:#020617; -fx-padding: 20;">

    <!-- 🔥 TITRE -->
    <Label text="🏠 Accueil"
           style="-fx-text-fill:white; -fx-font-size: 28px; -fx-font-weight: bold;" />

    <!-- 🔥 SOUS TITRE -->
    <Label text="🏆 Événements à suivre"
           style="-fx-text-fill:#cbd5f5; -fx-font-size: 18px;" />

    <!-- 🔥 SCROLL HORIZONTAL -->
    <ScrollPane fitToWidth="true"
                hbarPolicy="AS_NEEDED"
                vbarPolicy="NEVER"
                VBox.vgrow="ALWAYS"
                style="-fx-background:transparent;">

        <GridPane fx:id="eventsContainer"
                  hgap="20"
                  vgap="20"
                  style="-fx-padding:20;"/>
    </ScrollPane>

</VBox>