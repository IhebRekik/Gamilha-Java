<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gamilha.controllers.admin.AdminAnalyticsController"
      spacing="0" style="-fx-background-color:#0d1117;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:#111827;-fx-border-color:transparent transparent #1f2937 transparent;-fx-border-width:0 0 1 0;-fx-padding:20 28;">
        <VBox spacing="3">
            <Label text="📊 Analytiques Streams &amp; Donations"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#f9fafb;"/>
            <Label text="Métriques en temps réel · Aucune donnée externe · Tables existantes uniquement"
                   style="-fx-font-size:12px;-fx-text-fill:#6b7280;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="↺ Actualiser" onAction="#onRefresh"
                style="-fx-background-color:#1f2937;-fx-text-fill:#9ca3af;-fx-border-color:#374151;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:8 18;-fx-cursor:hand;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent;-fx-border-color:transparent;">
        <VBox spacing="20">
            <padding><Insets topRightBottomLeft="24"/></padding>

            <!-- ══ KPI Cards ══ -->
            <HBox spacing="14">

                <VBox HBox.hgrow="ALWAYS" spacing="6"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:18 20;">
                    <Label text="💰 REVENUS TOTAUX" style="-fx-text-fill:#6b7280;-fx-font-size:10px;-fx-font-weight:bold;"/>
                    <Label fx:id="lblRevTotal" text="…"
                           style="-fx-font-size:30px;-fx-font-weight:bold;-fx-text-fill:#4ade80;"/>
                    <Label text="sur toute la plateforme" style="-fx-text-fill:#374151;-fx-font-size:11px;"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" spacing="6"
                      style="-fx-background-color:#111827;-fx-border-color:#dc2626;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:18 20;">
                    <Label text="🔴 STREAMS LIVE" style="-fx-text-fill:#6b7280;-fx-font-size:10px;-fx-font-weight:bold;"/>
                    <Label fx:id="lblLiveNow" text="…"
                           style="-fx-font-size:30px;-fx-font-weight:bold;-fx-text-fill:#f87171;"/>
                    <Label fx:id="lblViewersNow" text="… viewers en direct"
                           style="-fx-text-fill:#374151;-fx-font-size:11px;"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" spacing="6"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:18 20;">
                    <Label text="🎯 DON MOYEN" style="-fx-text-fill:#6b7280;-fx-font-size:10px;-fx-font-weight:bold;"/>
                    <Label fx:id="lblAvgDon" text="…"
                           style="-fx-font-size:30px;-fx-font-weight:bold;-fx-text-fill:#f9fafb;"/>
                    <Label text="par donation" style="-fx-text-fill:#374151;-fx-font-size:11px;"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" spacing="6"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:18 20;">
                    <Label text="📈 TAUX CONVERSION" style="-fx-text-fill:#6b7280;-fx-font-size:10px;-fx-font-weight:bold;"/>
                    <Label fx:id="lblConversion" text="…"
                           style="-fx-font-size:30px;-fx-font-weight:bold;-fx-text-fill:#a78bfa;"/>
                    <Label text="streams avec donations" style="-fx-text-fill:#374151;-fx-font-size:11px;"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" spacing="6"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:18 20;">
                    <Label text="👥 DONATEURS UNIQUES" style="-fx-text-fill:#6b7280;-fx-font-size:10px;-fx-font-weight:bold;"/>
                    <Label fx:id="lblUniqueDonors" text="…"
                           style="-fx-font-size:30px;-fx-font-weight:bold;-fx-text-fill:#f9fafb;"/>
                    <Label text="utilisateurs ont donné" style="-fx-text-fill:#374151;-fx-font-size:11px;"/>
                </VBox>

            </HBox>

            <!-- ══ Graphiques ══ -->
            <HBox spacing="16">
                <!-- Revenus mensuels -->
                <VBox HBox.hgrow="ALWAYS" spacing="10"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:18 20;">
                    <Label text="💶 Revenus mensuels — 6 derniers mois"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#e5e7eb;"/>
                    <BarChart fx:id="revenueChart" prefHeight="230"
                              animated="false" legendVisible="false"
                              style="-fx-background-color:transparent;-fx-border-color:transparent;">
                        <xAxis><CategoryAxis fx:id="revenueXAxis"/></xAxis>
                        <yAxis><NumberAxis fx:id="revenueYAxis" label="€"/></yAxis>
                    </BarChart>
                </VBox>

                <!-- Revenus par jeu -->
                <VBox prefWidth="340" spacing="10"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:18 20;">
                    <Label text="🎮 Revenus par jeu"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#e5e7eb;"/>
                    <BarChart fx:id="gameChart" prefHeight="230"
                              animated="false" legendVisible="false"
                              style="-fx-background-color:transparent;-fx-border-color:transparent;">
                        <xAxis><CategoryAxis fx:id="gameXAxis"/></xAxis>
                        <yAxis><NumberAxis fx:id="gameYAxis" label="€"/></yAxis>
                    </BarChart>
                </VBox>
            </HBox>

            <!-- ══ Tableaux ══ -->
            <HBox spacing="16">

                <!-- Top streamers -->
                <VBox HBox.hgrow="ALWAYS" spacing="8"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:18 20;">
                    <Label text="🏆 Top Streamers par revenus"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#e5e7eb;"/>
                    <!-- Header -->
                    <HBox style="-fx-border-color:transparent transparent #1f2937 transparent;-fx-border-width:0 0 1 0;-fx-padding:0 14 8 14;">
                        <Label text="Streamer" style="-fx-text-fill:#4b5563;-fx-font-size:11px;" HBox.hgrow="ALWAYS"/>
                        <Label text="Streams"  style="-fx-text-fill:#4b5563;-fx-font-size:11px;" prefWidth="80"/>
                        <Label text="Revenus"  style="-fx-text-fill:#4b5563;-fx-font-size:11px;" prefWidth="90"/>
                        <Label text="Viewers"  style="-fx-text-fill:#4b5563;-fx-font-size:11px;" prefWidth="80"/>
                    </HBox>
                    <VBox fx:id="topStreamersBox" spacing="6"/>
                </VBox>

                <!-- Top streams -->
                <VBox HBox.hgrow="ALWAYS" spacing="8"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:18 20;">
                    <Label text="📡 Top Streams par revenus"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#e5e7eb;"/>
                    <HBox style="-fx-border-color:transparent transparent #1f2937 transparent;-fx-border-width:0 0 1 0;-fx-padding:0 14 8 14;">
                        <Label text="Titre"    style="-fx-text-fill:#4b5563;-fx-font-size:11px;" HBox.hgrow="ALWAYS"/>
                        <Label text="Jeu"      style="-fx-text-fill:#4b5563;-fx-font-size:11px;" prefWidth="80"/>
                        <Label text="Revenus"  style="-fx-text-fill:#4b5563;-fx-font-size:11px;" prefWidth="90"/>
                        <Label text="Dons"     style="-fx-text-fill:#4b5563;-fx-font-size:11px;" prefWidth="60"/>
                    </HBox>
                    <VBox fx:id="topStreamsBox" spacing="6"/>
                </VBox>

            </HBox>

            <!-- ══ Score engagement + Alertes ══ -->
            <HBox spacing="16">

                <!-- Score engagement -->
                <VBox HBox.hgrow="ALWAYS" spacing="10"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:18 20;">
                    <VBox spacing="3">
                        <Label text="⚡ Score d'engagement"
                               style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#e5e7eb;"/>
                        <Label text="(donations × 2) + (viewers × 0.5)"
                               style="-fx-font-size:11px;-fx-text-fill:#4b5563;"/>
                    </VBox>
                    <VBox fx:id="engagementBox" spacing="8"/>
                </VBox>

                <!-- Alertes automatiques -->
                <VBox prefWidth="360" spacing="10"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:18 20;">
                    <Label text="🔔 Alertes automatiques"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#e5e7eb;"/>
                    <VBox fx:id="alertsBox" spacing="8"/>
                </VBox>

            </HBox>

        </VBox>
    </ScrollPane>
</VBox>
