<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      style="-fx-background-color:#0a0f1e;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gamilha.controllers.playlist.ShowPlaylistUserController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- HEADER -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnRetour" text="← Retour aux playlists"
                style="-fx-background-color:#374151;-fx-text-fill:white;-fx-background-radius:6;-fx-padding:8 16;"/>
        <Label text="📋 Détails de la Playlist"
               style="-fx-text-fill:white;-fx-font-size:20;-fx-font-weight:bold;"/>
    </HBox>

    <!-- INFO CARD -->
    <VBox spacing="14"
          style="-fx-background-color:#1e293b;-fx-background-radius:10;-fx-padding:20;">

        <Label text="Informations générales"
               style="-fx-text-fill:#c084fc;-fx-font-size:15;-fx-font-weight:bold;"/>

        <HBox spacing="20">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Titre" style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <Label fx:id="lblTitre"
                       style="-fx-text-fill:white;-fx-font-size:16;-fx-font-weight:bold;"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Catégorie" style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <Label fx:id="lblCategorie" style="-fx-text-fill:#94a3b8;-fx-font-size:14;"/>
            </VBox>
        </HBox>

        <HBox spacing="20">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Niveau" style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <Label fx:id="lblNiveau" style="-fx-text-fill:#38bdf8;-fx-font-size:14;"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Date de création" style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <Label fx:id="lblDate" style="-fx-text-fill:#94a3b8;-fx-font-size:13;"/>
            </VBox>
        </HBox>

        <VBox spacing="5">
            <Label text="Description" style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
            <Label fx:id="lblDescription" wrapText="true"
                   style="-fx-text-fill:#cbd5e1;-fx-font-size:13;"/>
        </VBox>

    </VBox>

    <!-- VIDÉOS -->
    <Label text="🎬 Vidéos de la playlist"
           style="-fx-text-fill:white;-fx-font-size:17;-fx-font-weight:bold;"/>

    <ScrollPane VBox.vgrow="ALWAYS"
                fitToWidth="true"
                style="-fx-background-color:transparent;-fx-background:#020617;-fx-border-color:transparent;">
        <GridPane fx:id="videosGrid"
                  hgap="0" vgap="0"
                  style="-fx-background-color:#020617;-fx-border-color:#1e293b;-fx-border-radius:8;">
        </GridPane>
    </ScrollPane>

</VBox>
