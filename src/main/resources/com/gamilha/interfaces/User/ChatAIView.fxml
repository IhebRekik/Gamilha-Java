<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>

<VBox spacing="20"
      alignment="TOP_CENTER"
      style="-fx-background-color:#0f1020; -fx-padding:30;"
      prefWidth="1200"
      prefHeight="800"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gamilha.controllers.ChatAIController">

    <!-- 🔥 TITLE -->
    <Label text="🤖 Chat AI"
           style="-fx-text-fill:#ff66cc;
                  -fx-font-size:28;
                  -fx-font-weight:bold;" />

    <!-- 🔥 CHAT AREA -->
    <ScrollPane fitToWidth="true"
                vbarPolicy="AS_NEEDED"
                style="-fx-background:#0f172a;">

        <content>
            <VBox fx:id="chatBox" spacing="10" style="-fx-padding:10;"/>
        </content>

    </ScrollPane>

    <!-- 🔥 INPUT -->
    <HBox spacing="10">

        <TextField fx:id="inputField"
                   promptText="Pose ta question..."
                   HBox.hgrow="ALWAYS"
                   style="
                       -fx-background-color:#1e1e2f;
                       -fx-text-fill:white;
                       -fx-background-radius:10;
                       -fx-padding:10;
                   "/>

        <Button text="Envoyer"
                onAction="#sendMessage"
                style="
                    -fx-background-color:#ff66cc;
                    -fx-text-fill:white;
                    -fx-background-radius:10;
                    -fx-font-weight:bold;
                "/>

    </HBox>

</VBox>