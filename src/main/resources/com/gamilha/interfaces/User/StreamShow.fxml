<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.web.*?>
<?import javafx.geometry.Insets?>

<!--
  StreamShow.fxml — identique à show.html.twig Symfony
  Sections :
    1. Navbar + header (titre + badge statut)
    2. Thumbnail + infos (jeu, viewers, desc, date, lien player)
    3. Player api.video (WebView) OU écran "Live stream offline."
    4. Bloc OBS (streamer uniquement)
    5. Donations emoji rapides
    6. Grille donations reçues
    7. Bouton Prédiction IA (streamer uniquement)
-->
<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controllers.StreamShowController"
            stylesheets="@../../css/style.css"
            prefWidth="1280" prefHeight="800">

    <!-- ══ NAVBAR ══════════════════════════════════════════════════════ -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="navbar">
                <padding><Insets topRightBottomLeft="14"/></padding>
                <Label text="🎮 GAMILHA" styleClass="brand"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="← Retour aux streams" onAction="#onBack"         styleClass="btn-secondary"/>
                <Button text="✏ Modifier"            onAction="#onEdit"         styleClass="btn-warning"/>
                <Button text="💰 Donations"           onAction="#onAllDonations" styleClass="btn-primary"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="page-header">
                <padding><Insets top="14" right="24" bottom="10" left="24"/></padding>
                <Label fx:id="lblTitle" text="" styleClass="page-title" wrapText="true"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStatus" text=""/>
            </HBox>
        </VBox>
    </top>

    <!-- ══ CONTENU PRINCIPAL ══════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-dark">
            <VBox spacing="20">
                <padding><Insets topRightBottomLeft="28"/></padding>

                <!-- ── 1. Thumbnail + Infos ──────────────────────────── -->
                <HBox spacing="24" alignment="TOP_LEFT">
                    <ImageView fx:id="imgThumb" fitWidth="520" fitHeight="292"
                               preserveRatio="true"/>

                    <VBox spacing="14" HBox.hgrow="ALWAYS" styleClass="info-panel">
                        <padding><Insets topRightBottomLeft="22"/></padding>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="lblGame"    text="" styleClass="badge-game"/>
                            <Label fx:id="lblViewers" text="" styleClass="badge-viewers"/>
                        </HBox>

                        <Label fx:id="lblDesc" text="" styleClass="show-desc" wrapText="true"/>
                        <Label fx:id="lblDate" text="" styleClass="meta-lbl"/>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="🔗" style="-fx-font-size:13px;"/>
                            <Hyperlink fx:id="lnkUrl" text="" styleClass="link-style"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- ── 2. Player api.video OU écran offline ──────────── -->
                <!--
                  Identique à Twig :
                    {% if stream.url %} → iframe api.video
                    {% else %}          → "Live stream offline."
                  Géré par StreamShowController.setupPlayer()
                -->

                <!-- Player WebView (visible quand isLive ou url non nul) -->
                <VBox fx:id="playerBox" spacing="0" visible="false" managed="false"
                      style="-fx-background-color:#000;">
                    <WebView fx:id="webPlayer" prefWidth="1180" prefHeight="664"/>
                </VBox>

                <!-- Écran offline (identique screenshot Gamilha) -->
                <VBox fx:id="offlineBox" alignment="CENTER" spacing="18" visible="true" managed="true"
                      prefHeight="380"
                      style="-fx-background-color:linear-gradient(to bottom right, #1a0a2e, #0a0a1a, #2d1a00);
                             -fx-border-radius:12;-fx-background-radius:12;">
                    <padding><Insets topRightBottomLeft="60"/></padding>

                    <!-- Logo Gamilha centré (remplace le logo api.video du screenshot) -->
                    <Label text="◈" style="-fx-font-size:80px;-fx-text-fill:#8b5cf6;-fx-opacity:0.6;"/>

                    <!-- Titre offline -->
                    <HBox alignment="CENTER" spacing="14">
                        <Label text="Live stream offline."
                               style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                        <Label text="📷" style="-fx-font-size:24px;-fx-opacity:0.6;"/>
                    </HBox>

                    <!-- Sous-titre -->
                    <Label text="Playback will start automatically when the stream begins."
                           style="-fx-font-size:14px;-fx-text-fill:#94a3b8;"/>

                    <!-- Provider -->
                    <HBox alignment="CENTER" spacing="8">
                        <Label text="◈" style="-fx-font-size:14px;-fx-text-fill:#60a5fa;"/>
                        <Label text="api.video"
                               style="-fx-font-size:13px;-fx-text-fill:#60a5fa;-fx-font-weight:bold;"/>
                    </HBox>
                </VBox>

                <!-- ── 3. Bloc OBS (streamer uniquement) ─────────────── -->
                <!--
                  Visible si isStreamer && streamKey != null
                  Identique à Twig :
                    {% if app.user == stream.user and stream.rtmpServer and stream.streamKey %}
                    Configurer OBS pour streamer :
                    Service : Personnalisé
                    Serveur : rtmp://broadcast.api.video/s
                    Clé de flux : <streamKey>
                -->
                <VBox fx:id="obsBox" spacing="14"
                      style="-fx-background-color:#0c1a2e;-fx-border-color:#1d4ed8;
                             -fx-border-radius:10;-fx-background-radius:10;"
                      visible="false" managed="false">
                    <padding><Insets topRightBottomLeft="22"/></padding>

                    <!-- Titre bloc -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="🎬" style="-fx-font-size:22px;"/>
                        <VBox spacing="2">
                            <Label text="Configurer OBS pour streamer :"
                                   style="-fx-text-fill:#60a5fa;-fx-font-size:15px;-fx-font-weight:bold;"/>
                            <Label text="Service : Personnalisé — copiez ces valeurs dans OBS → Paramètres → Flux"
                                   style="-fx-text-fill:#64748b;-fx-font-size:12px;"/>
                        </VBox>
                    </HBox>

                    <Separator style="-fx-background-color:#1d4ed8;"/>

                    <!-- Serveur RTMP -->
                    <VBox spacing="6">
                        <Label text="SERVEUR :"
                               style="-fx-text-fill:#60a5fa;-fx-font-size:11px;-fx-font-weight:bold;"/>
                        <HBox spacing="10" alignment="CENTER_LEFT"
                              style="-fx-background-color:#0f1a2e;-fx-border-color:#1e3a5f;
                                     -fx-border-radius:8;-fx-background-radius:8;-fx-padding:10 14;">
                            <Label fx:id="lblRtmp" text="" styleClass="obs-code" HBox.hgrow="ALWAYS" wrapText="true"/>
                            <Button fx:id="btnCopyRtmp" text="📋 Copier" onAction="#onCopyRtmp"
                                    styleClass="btn-obs-copy" minWidth="90"/>
                        </HBox>
                    </VBox>

                    <!-- Clé de flux -->
                    <VBox spacing="6">
                        <Label text="CLÉ DE FLUX :"
                               style="-fx-text-fill:#60a5fa;-fx-font-size:11px;-fx-font-weight:bold;"/>
                        <HBox spacing="10" alignment="CENTER_LEFT"
                              style="-fx-background-color:#0f1a2e;-fx-border-color:#1e3a5f;
                                     -fx-border-radius:8;-fx-background-radius:8;-fx-padding:10 14;">
                            <Label fx:id="lblKey" text="" styleClass="obs-code" HBox.hgrow="ALWAYS" wrapText="true"/>
                            <Button fx:id="btnCopyKey" text="📋 Copier" onAction="#onCopyKey"
                                    styleClass="btn-obs-copy" minWidth="90"/>
                        </HBox>
                    </VBox>

                    <!-- Instruction (identique screenshot) -->
                    <Label text="⚡ Démarre le streaming dans OBS → attends 20-60s → le player se met à jour automatiquement."
                           style="-fx-text-fill:#94a3b8;-fx-font-size:12px;" wrapText="true"/>

                    <!-- Avertissement clé -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="⚠" style="-fx-font-size:14px;"/>
                        <Label text="Ne partagez jamais votre clé de flux"
                               style="-fx-text-fill:#f59e0b;-fx-font-size:12px;-fx-font-weight:bold;"/>
                    </HBox>
                </VBox>

                <!-- ── 4. Donations emoji rapides ─────────────────────── -->
                <VBox spacing="12" styleClass="section-box">
                    <padding><Insets topRightBottomLeft="18"/></padding>
                    <Label text="💸 Faire une donation" styleClass="section-title"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button text="🍩  1 €"  onAction="#onDonate1"  styleClass="emoji-btn"      prefWidth="170"/>
                        <Button text="🍕  5 €"  onAction="#onDonate5"  styleClass="emoji-btn"      prefWidth="170"/>
                        <Button text="💎  10 €" onAction="#onDonate10" styleClass="emoji-btn-blue" prefWidth="170"/>
                        <Button text="🚀  50 €" onAction="#onDonate50" styleClass="emoji-btn-red"  prefWidth="170"/>
                    </HBox>
                </VBox>

                <!-- ── 5. Donations reçues ────────────────────────────── -->
                <VBox spacing="10" styleClass="section-box">
                    <padding><Insets topRightBottomLeft="18"/></padding>
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="📋 Donations reçues" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblCount" text="" styleClass="count-label"/>
                        <Label fx:id="lblTotal" text="Total : 0,00 €" styleClass="total-badge"/>
                    </HBox>
                    <FlowPane fx:id="donationGrid" hgap="14" vgap="14">
                        <padding><Insets top="8" bottom="4"/></padding>
                    </FlowPane>
                </VBox>

                <!-- ── 6. Bouton Prédiction IA (streamer uniquement) ──── -->
                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="btnPrediction"
                            text="📊 Voir ma Prédiction IA de streams"
                            onAction="#onPrediction"
                            styleClass="btn-primary"
                            prefWidth="320"
                            visible="false" managed="false"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- ══ FOOTER ══════════════════════════════════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER" styleClass="footer">
            <padding><Insets topRightBottomLeft="10"/></padding>
            <Label text="Gamilha — E-Sport &amp; Tournois" styleClass="footer-text"/>
        </HBox>
    </bottom>
</BorderPane>
