<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.web.WebView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controllers.StreamShowController"
            stylesheets="@../css/styles.css,@../css/gamilha.css"
            prefWidth="1280" prefHeight="800">

    <top>
        <VBox style="-fx-background-color:#0d1117;-fx-border-color:transparent transparent #1f2937 transparent;-fx-border-width:0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color:#111827;-fx-padding:12 20;">
                <Label text="🎮 GAMILHA" style="-fx-text-fill:#c84cff;-fx-font-size:17px;-fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="← Retour"         onAction="#onBack"         styleClass="nav-action-btn"/>
                <Button text="✏ Modifier"        onAction="#onEdit"         styleClass="nav-action-btn-warn"/>
                <Button text="💰 Donations"      onAction="#onAllDonations" styleClass="nav-action-btn-purple"/>
                <Button fx:id="btnPrediction"
                        text="🤖 Prévision IA"  onAction="#onPrediction"   styleClass="nav-action-btn-purple"
                        visible="false" managed="false"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color:#0d1117;-fx-padding:10 20 8 20;">
                <Label fx:id="lblTitle" text="" wrapText="true"
                       style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#f9fafb;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStatus" text=""/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:#0d1117;-fx-background:transparent;">
            <VBox spacing="0" style="-fx-background-color:#0d1117;">

                <!-- ══ PLAYER api.video (TOUS LES USERS voient le player) ══ -->
                <!-- Visible quand isLive=true ou status="live" -->
                <VBox fx:id="playerBox" visible="false" managed="false"
                      style="-fx-background-color:#000;">
                    <StackPane fx:id="playerStack" prefHeight="506" style="-fx-background-color:#000000;">
                        <MediaView fx:id="playerMediaView" visible="false" managed="false"/>
                        <Canvas fx:id="playerCanvas" visible="false" managed="false"/>
                        <WebView fx:id="playerView" prefHeight="506"
                                 style="-fx-background-color:#000000;"/>
                    </StackPane>
                </VBox>

                <!-- ══ ÉCRAN OFFLINE (quand OBS pas connecté) ══ -->
                <!-- Identique screenshot Symfony : gradient sombre + texte + logo api.video -->
                <VBox fx:id="offlineBox" alignment="CENTER" spacing="20"
                      prefHeight="380" visible="true" managed="true"
                      style="-fx-background-color:linear-gradient(to bottom right,#0a0014,#0a0a0a,#1a0a00);
                             -fx-border-color:transparent;">
                    <padding><Insets topRightBottomLeft="60"/></padding>

                    <!-- Logo Gamilha centré -->
                    <Label text="◈" style="-fx-font-size:90px;-fx-text-fill:#8b5cf6;-fx-opacity:0.5;"/>

                    <!-- "Live stream offline." identique au screenshot -->
                    <HBox alignment="CENTER" spacing="16">
                        <Label text="Live stream offline."
                               style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
                        <Label text="📷" style="-fx-font-size:24px;-fx-opacity:0.5;"/>
                    </HBox>

                    <Label text="Playback will start automatically when the stream begins."
                           style="-fx-font-size:14px;-fx-text-fill:#6b7280;"/>

                    <!-- api.video branding -->
                    <HBox alignment="CENTER" spacing="8">
                        <Label text="◈" style="-fx-font-size:16px;-fx-text-fill:#60a5fa;"/>
                        <Label text="api.video"
                               style="-fx-font-size:13px;-fx-text-fill:#60a5fa;-fx-font-weight:bold;"/>
                    </HBox>
                </VBox>

                <!-- ══ BLOC OBS (STREAMER UNIQUEMENT) ══ -->
                <VBox fx:id="obsBox" visible="false" managed="false"
                      style="-fx-background-color:#e0f7f7;-fx-border-color:#a5f3eb transparent transparent transparent;-fx-border-width:3 0 0 0;">
                    <padding><Insets top="28" right="40" bottom="32" left="40"/></padding>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <VBox.margin><Insets bottom="18"/></VBox.margin>
                        <Label text="📡" style="-fx-font-size:28px;"/>
                        <VBox spacing="2">
                            <Label text="Configurer OBS Studio pour streamer"
                                   style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#0f4c4c;"/>
                            <Label text="Copiez ces valeurs dans OBS → Paramètres → Flux → Service Personnalisé"
                                   style="-fx-font-size:12px;-fx-text-fill:#0e7490;"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="16">
                        <!-- Service -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#cffafe;-fx-border-color:#a5f3eb;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:14 16;">
                            <Label text="SERVICE" style="-fx-text-fill:#0e7490;-fx-font-size:10px;-fx-font-weight:bold;"/>
                            <Label text="Personnalisé" style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#0f4c4c;"/>
                        </VBox>
                        <!-- Serveur RTMP -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#cffafe;-fx-border-color:#a5f3eb;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:14 16;">
                            <Label text="SERVEUR RTMP" style="-fx-text-fill:#0e7490;-fx-font-size:10px;-fx-font-weight:bold;"/>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label fx:id="lblRtmp" text=""
                                       style="-fx-font-family:'Consolas','Courier New',monospace;-fx-font-size:13px;-fx-text-fill:#0f4c4c;-fx-font-weight:bold;"
                                       HBox.hgrow="ALWAYS" wrapText="true"/>
                                <Button fx:id="btnCopyRtmp" text="📋" onAction="#onCopyRtmp"
                                        style="-fx-background-color:#0891b2;-fx-text-fill:white;-fx-background-radius:6;-fx-cursor:hand;-fx-padding:4 10;-fx-font-size:13px;"/>
                            </HBox>
                        </VBox>
                        <!-- Clé de flux -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#cffafe;-fx-border-color:#a5f3eb;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:14 16;">
                            <Label text="CLÉ DE FLUX" style="-fx-text-fill:#0e7490;-fx-font-size:10px;-fx-font-weight:bold;"/>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label fx:id="lblKey" text=""
                                       style="-fx-font-family:'Consolas','Courier New',monospace;-fx-font-size:13px;-fx-text-fill:#0f4c4c;-fx-font-weight:bold;"
                                       HBox.hgrow="ALWAYS" wrapText="true"/>
                                <Button fx:id="btnCopyKey" text="📋" onAction="#onCopyKey"
                                        style="-fx-background-color:#0891b2;-fx-text-fill:white;-fx-background-radius:6;-fx-cursor:hand;-fx-padding:4 10;-fx-font-size:13px;"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <HBox spacing="24" alignment="CENTER_LEFT">
                        <VBox.margin><Insets top="16"/></VBox.margin>
                        <Label text="▶  Lance OBS → Démarrer le streaming → attends 20-60s → le player se met à jour automatiquement"
                               style="-fx-text-fill:#0e7490;-fx-font-size:13px;-fx-font-style:italic;"
                               wrapText="true" HBox.hgrow="ALWAYS"/>
                        <Label text="⚠  Ne partagez jamais votre clé"
                               style="-fx-text-fill:#b45309;-fx-font-size:12px;-fx-font-weight:bold;"/>
                    </HBox>
                </VBox>

                <!-- ══ INFOS STREAM + THUMBNAIL ══ -->
                <HBox spacing="24" alignment="TOP_LEFT"
                      style="-fx-padding:24 28 0 28;-fx-background-color:#0d1117;">
                    <ImageView fx:id="imgThumb" fitWidth="520" fitHeight="293"
                               preserveRatio="true"
                               style="-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.5),20,0,0,4);"/>
                    <VBox spacing="14" HBox.hgrow="ALWAYS"
                          style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:20;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="lblGame" text=""
                                   style="-fx-background-color:#1e3a5f;-fx-text-fill:#67e8f9;-fx-background-radius:20;-fx-padding:3 12;-fx-font-size:12px;-fx-font-weight:bold;"/>
                            <Label fx:id="lblViewers" text=""
                                   style="-fx-background-color:#1f2937;-fx-text-fill:#94a3b8;-fx-background-radius:20;-fx-padding:3 12;-fx-font-size:12px;"/>
                        </HBox>
                        <Label fx:id="lblDesc" text="" wrapText="true"
                               style="-fx-text-fill:#9ca3af;-fx-font-size:14px;-fx-line-spacing:2;"/>
                        <Label fx:id="lblDate" text=""
                               style="-fx-text-fill:#4b5563;-fx-font-size:12px;"/>
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="🔗" style="-fx-text-fill:#4b5563;-fx-font-size:12px;"/>
                            <Hyperlink fx:id="lnkUrl" text="" style="-fx-text-fill:#818cf8;-fx-font-size:12px;"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- ══ BOUTONS DONATION (cachés pour le streamer) ══ -->
                <HBox fx:id="donateButtonsBox" spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:20;">
                    <VBox.margin><Insets top="20" right="28" left="28"/></VBox.margin>
                    <Label text="💸 Soutenir ce stream"
                           style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#f9fafb;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🍩  1 €"  onAction="#onDonate1"  styleClass="emoji-btn"      prefWidth="160"/>
                    <Button text="🍕  5 €"  onAction="#onDonate5"  styleClass="emoji-btn"      prefWidth="160"/>
                    <Button text="💎  10 €" onAction="#onDonate10" styleClass="emoji-btn-blue" prefWidth="160"/>
                    <Button text="🚀  50 €" onAction="#onDonate50" styleClass="emoji-btn-red"  prefWidth="160"/>
                </HBox>

                <!-- ══ DONATIONS REÇUES ══ -->
                <VBox spacing="12"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:20;">
                    <VBox.margin><Insets top="16" right="28" bottom="28" left="28"/></VBox.margin>
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="📋 Donations reçues"
                               style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#f9fafb;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblCount" text="" style="-fx-text-fill:#6b7280;-fx-font-size:12px;"/>
                        <Label fx:id="lblTotal" text="Total : 0,00 €"
                               style="-fx-background-color:rgba(74,222,128,0.15);-fx-text-fill:#4ade80;-fx-font-weight:bold;-fx-border-color:rgba(74,222,128,0.3);-fx-border-radius:20;-fx-background-radius:20;-fx-padding:4 14;"/>
                    </HBox>
                    <FlowPane fx:id="donationGrid" hgap="14" vgap="14">
                        <padding><Insets top="6" bottom="6"/></padding>
                    </FlowPane>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              style="-fx-background-color:#111827;-fx-border-color:#1f2937 transparent transparent transparent;-fx-border-width:1 0 0 0;-fx-padding:10;">
            <Label text="Gamilha — E-Sport &amp; Tournois" style="-fx-text-fill:#374151;-fx-font-size:11px;"/>
        </HBox>
    </bottom>
</BorderPane>
