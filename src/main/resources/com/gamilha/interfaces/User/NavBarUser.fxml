<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controllers.NavBarUserController">

    <!-- NAVBAR -->
    <top>

        <HBox spacing="25"
              alignment="CENTER_LEFT"
              style="-fx-background-color:linear-gradient(to right,#0f1020,#1a1b3a);
                     -fx-padding:12 30;">

            <!-- LOGO -->
            <HBox spacing="8" alignment="CENTER_LEFT">

                <ImageView fitHeight="28"
                           fitWidth="28"
                           preserveRatio="true">

                    <image>
                        <Image url="@/com/gamilha/interfaces/images/logo.png"/>
                    </image>

                </ImageView>

                <Label text="Gamilha"
                       style="-fx-text-fill:#c84cff;
                  -fx-font-size:20;
                  -fx-font-weight:bold;" />

            </HBox>

            <!-- MENU -->
            <Button text="🏠 Accueil"
                    onAction="#goAccueil"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:white;-fx-font-size: 14" />

            <Button text="📅 Événements"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:white;
                            -fx-font-size: 14" />

            <Button text="👥 Équipes"
                    onAction="#goEquipe"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:white;-fx-font-size: 14" />

            <Button text="🎓 Playlists"
                    onAction="#goPlaylists"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:#c084fc;-fx-font-size: 14;-fx-font-weight:bold;" />

            <Button text="🎬 Vidéos"
                    onAction="#goVideos"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:white;-fx-font-size: 14" />

            <Button text="🤖 Gamilha AI"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:white;-fx-font-size: 14" />

            <Button text="👤 Amis"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:white;-fx-font-size: 14" />

            <Button text="🔗 Réseaux"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:white;-fx-font-size: 14" />

            <Button text="📡 Streams"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:white;-fx-font-size: 14" />

            <Button text="💎 Abonnements"
                    onAction="#goAbonnement"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:white;-fx-font-size: 14" />

            <!-- espace -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- USER -->
            <Label fx:id="welcomeLabel"
                   style="-fx-text-fill:white; -fx-font-size:14;" />

        </HBox>

    </top>

    <!-- CONTENU PAGE -->
    <center>

        <BorderPane fx:id="contentArea"/>

    </center>

</BorderPane>