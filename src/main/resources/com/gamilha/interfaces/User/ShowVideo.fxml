<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      style="-fx-background-color:#0a0f1e;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gamilha.controllers.video.ShowVideoController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- HEADER -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnRetour" text="← Retour aux vidéos"
                style="-fx-background-color:#374151;-fx-text-fill:white;-fx-background-radius:6;-fx-padding:8 16;"/>
        <Label text="🎬 Détails de la Vidéo"
               style="-fx-text-fill:white;-fx-font-size:20;-fx-font-weight:bold;"/>
    </HBox>

    <!-- INFO CARD -->
    <VBox spacing="16"
          style="-fx-background-color:#1e293b;-fx-background-radius:12;-fx-padding:25;">

        <!-- Titre -->
        <VBox spacing="5">
            <Label text="Titre" style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
            <Label fx:id="lblTitre"
                   style="-fx-text-fill:white;-fx-font-size:18;-fx-font-weight:bold;"/>
        </VBox>

        <HBox spacing="20">
            <!-- Niveau -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Niveau" style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <Label fx:id="lblNiveau"
                       style="-fx-text-fill:#38bdf8;-fx-font-size:14;"/>
            </VBox>
            <!-- Durée -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Durée" style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <Label fx:id="lblDuration"
                       style="-fx-text-fill:#34d399;-fx-font-size:14;"/>
            </VBox>
            <!-- Premium -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Accès" style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <Label fx:id="lblPremium"
                       style="-fx-text-fill:#f59e0b;-fx-font-size:14;"/>
            </VBox>
            <!-- Playlist -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Playlist" style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <Label fx:id="lblPlaylist"
                       style="-fx-text-fill:#c084fc;-fx-font-size:14;"/>
            </VBox>
        </HBox>

        <!-- Description -->
        <VBox spacing="5">
            <Label text="Description" style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
            <Label fx:id="lblDescription"
                   wrapText="true"
                   style="-fx-text-fill:#cbd5e1;-fx-font-size:13;"/>
        </VBox>

        <!-- URL -->
        <VBox spacing="5">
            <Label text="URL de la vidéo" style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
            <Label fx:id="lblUrl"
                   wrapText="true"
                   style="-fx-text-fill:#60a5fa;-fx-font-size:13;"/>
        </VBox>

    </VBox>

</VBox>
