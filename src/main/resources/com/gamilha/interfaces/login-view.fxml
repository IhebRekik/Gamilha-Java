<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.gamilha.controllers.LoginController"
           style="-fx-background-color:linear-gradient(to bottom right,#0a0d1a,#0f1629,#0a0d1a);">

    <!-- Card centered -->
    <VBox alignment="TOP_CENTER" spacing="0"
          maxWidth="400" prefWidth="400"
          style="-fx-background-color:#12172b;
                 -fx-background-radius:20;
                 -fx-border-color:#1e2a45;
                 -fx-border-radius:20;
                 -fx-border-width:1;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.7),40,0,0,16);">

        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <!-- Title -->
        <Label text="Connexion"
               style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:#a78bfa;">
            <VBox.margin><Insets bottom="28"/></VBox.margin>
        </Label>

        <!-- Error banner -->
        <Label fx:id="errorLabel" wrapText="true" maxWidth="320"
               style="-fx-text-fill:#fca5a5;-fx-background-color:#3d1111;
                      -fx-padding:10 14;-fx-background-radius:10;-fx-font-size:13px;
                      -fx-border-color:#7f1d1d;-fx-border-radius:10;-fx-border-width:1;"
               visible="false" managed="false">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Label>

        <!-- Countdown label -->
        <Label fx:id="lockCountdown"
               style="-fx-text-fill:#fbbf24;-fx-font-size:13px;-fx-font-weight:bold;"
               visible="false" managed="false">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>

        <!-- EMAIL -->
        <Label text="✉  Email"
               style="-fx-text-fill:#c4c4c4;-fx-font-size:13px;-fx-font-weight:bold;"/>
        <TextField fx:id="emailField"
                   promptText="email@exemple.com"
                   style="-fx-background-color:#1c2235;-fx-text-fill:white;
                          -fx-prompt-text-fill:#4b5563;-fx-border-color:#2d3a55;
                          -fx-border-radius:10;-fx-background-radius:10;
                          -fx-padding:12 14;-fx-font-size:14px;">
            <VBox.margin><Insets top="6" bottom="16"/></VBox.margin>
        </TextField>

        <!-- PASSWORD -->
        <Label text="🔒  Mot de passe"
               style="-fx-text-fill:#c4c4c4;-fx-font-size:13px;-fx-font-weight:bold;"/>

        <HBox spacing="0" alignment="CENTER"
              style="-fx-background-color:#1c2235;-fx-border-color:#2d3a55;
                     -fx-border-radius:10;-fx-background-radius:10;">
            <VBox.margin><Insets top="6" bottom="4"/></VBox.margin>

            <StackPane HBox.hgrow="ALWAYS">
                <PasswordField fx:id="passwordField"
                               promptText="Votre mot de passe"
                               style="-fx-background-color:transparent;-fx-text-fill:white;
                                      -fx-prompt-text-fill:#4b5563;-fx-border-color:transparent;
                                      -fx-background-radius:10;-fx-padding:12 14;-fx-font-size:14px;"/>
                <TextField fx:id="passwordVisible"
                           promptText="Votre mot de passe"
                           style="-fx-background-color:transparent;-fx-text-fill:white;
                                  -fx-prompt-text-fill:#4b5563;-fx-border-color:transparent;
                                  -fx-background-radius:10;-fx-padding:12 14;-fx-font-size:14px;"
                           visible="false" managed="false"/>
            </StackPane>

            <Button fx:id="eyeButton" text="👁"
                    onAction="#toggleEye"
                    style="-fx-background-color:transparent;-fx-text-fill:#64748b;
                           -fx-cursor:hand;-fx-font-size:16px;-fx-padding:8 12;
                           -fx-border-color:transparent;"/>
        </HBox>

        <Label text="ℹ  Cliquez sur l'œil pour afficher/masquer"
               style="-fx-text-fill:#475569;-fx-font-size:11px;">
            <VBox.margin><Insets bottom="14"/></VBox.margin>
        </Label>

        <!-- Remember me -->
        <CheckBox fx:id="rememberMeCheckbox"
                  text="  Se souvenir de moi"
                  style="-fx-text-fill:#94a3b8;-fx-font-size:13px;">
            <VBox.margin><Insets bottom="20"/></VBox.margin>
        </CheckBox>

        <!-- Login button -->
        <Button fx:id="loginButton"
                text="➡  Se connecter"
                onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color:#7c3aed;-fx-text-fill:white;
                       -fx-font-size:15px;-fx-font-weight:bold;
                       -fx-background-radius:12;-fx-cursor:hand;-fx-padding:13 0;
                       -fx-effect:dropshadow(gaussian,rgba(124,58,237,0.4),12,0,0,4);">
            <VBox.margin><Insets bottom="18"/></VBox.margin>
        </Button>

        <!-- Forgot password -->
        <HBox alignment="CENTER">
            <Button text="🔑  Mot de passe oublié ?"
                    onAction="#handleForgotPassword"
                    style="-fx-background-color:transparent;-fx-text-fill:#a78bfa;
                           -fx-font-size:13px;-fx-cursor:hand;-fx-border-color:transparent;
                           -fx-padding:4 0;">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Button>
        </HBox>

        <Separator style="-fx-border-color:#1e2a45;-fx-opacity:0.8;">
            <VBox.margin><Insets bottom="16"/></VBox.margin>
        </Separator>

        <!-- Register link -->
        <HBox alignment="CENTER" spacing="6">
            <Label text="Pas encore de compte ?"
                   style="-fx-text-fill:#64748b;-fx-font-size:13px;"/>
            <Button text="✚  Créer un compte"
                    onAction="#handleRegister"
                    style="-fx-background-color:transparent;-fx-text-fill:#a78bfa;
                           -fx-font-size:13px;-fx-cursor:hand;-fx-border-color:transparent;-fx-padding:0;"/>
        </HBox>

    </VBox>
</StackPane>
