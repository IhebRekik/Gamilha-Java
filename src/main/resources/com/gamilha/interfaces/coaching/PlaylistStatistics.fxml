<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gamilha.controllers.coaching.PlaylistStatisticsController"
      style="-fx-background-color:#111827;-fx-background-radius:12;-fx-padding:20;
             -fx-border-color:#334155;-fx-border-radius:12;">

    <Label text="Statistiques de la playlist"
           style="-fx-text-fill:#38bdf8;-fx-font-size:18;-fx-font-weight:bold;"/>

    <!-- KPI cards (built programmatically) -->
    <FlowPane fx:id="kpiPane" hgap="14" vgap="14"/>

    <!-- Charts row: PieChart + BarChart (built programmatically) -->
    <HBox fx:id="chartsBox" spacing="16"/>

    <!-- Info row: top video + last view -->
    <HBox spacing="16">
        <VBox spacing="8" HBox.hgrow="ALWAYS"
              style="-fx-background-color:#1e293b;-fx-background-radius:10;-fx-padding:14;">
            <Label text="Video la plus regardee" style="-fx-text-fill:#94a3b8;-fx-font-size:11;"/>
            <Label fx:id="lblTopVideo" wrapText="true"
                   style="-fx-text-fill:white;-fx-font-size:14;-fx-font-weight:bold;"/>
        </VBox>
        <VBox spacing="8" minWidth="220"
              style="-fx-background-color:#1e293b;-fx-background-radius:10;-fx-padding:14;">
            <Label text="Derniere lecture" style="-fx-text-fill:#94a3b8;-fx-font-size:11;"/>
            <Label fx:id="lblLastView" wrapText="true"
                   style="-fx-text-fill:white;-fx-font-size:14;-fx-font-weight:bold;"/>
        </VBox>
    </HBox>
</VBox>
