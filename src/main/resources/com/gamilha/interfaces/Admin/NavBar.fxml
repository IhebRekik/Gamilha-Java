<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controllers.NavBarAdminController"
            style="-fx-background-color:#0a0a0f;">

    <!-- ══ TOPBAR ══════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color:#0d0d1a;
                     -fx-border-color:transparent transparent rgba(139,92,246,0.2) transparent;
                     -fx-border-width:0 0 1 0;
                     -fx-padding:10 24;">
            <Label text="⚙ Admin Panel"
                   style="-fx-text-fill:#6b7280;-fx-font-size:12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text=""
                   style="-fx-text-fill:#94a3b8;-fx-font-size:13px;"/>
            <Label text="●"
                   style="-fx-text-fill:#22c55e;-fx-font-size:10px;"/>
        </HBox>
    </top>

    <!-- ══ SIDEBAR ═════════════════════════════════════════════════ -->
    <left>
        <VBox prefWidth="245" spacing="2"
              style="-fx-background-color:#0d0d1a;
                     -fx-border-color:transparent rgba(139,92,246,0.15) transparent transparent;
                     -fx-border-width:0 1 0 0;">
            <padding><Insets top="20" right="10" bottom="16" left="10"/></padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding:0 4 16 4;">
                <Label text="🎮" style="-fx-font-size:28px;"/>
                <VBox spacing="1">
                    <Label text="Gamilha"
                           style="-fx-text-fill:#c084fc;-fx-font-size:18px;-fx-font-weight:800;"/>
                    <Label text="Admin Panel"
                           style="-fx-text-fill:#4b5563;-fx-font-size:10px;"/>
                </VBox>
            </HBox>

            <Separator style="-fx-background-color:rgba(139,92,246,0.15);"/>
            <Region prefHeight="6"/>

            <!-- ── PRINCIPAL ────────────────────────────────────── -->
            <Label text="PRINCIPAL" styleClass="sidebar-section-label"/>
            <Button fx:id="btnDashboard"    text="📊  Dashboard"    onAction="#goDashboard"    styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnUtilisateurs" text="👥  Utilisateurs" onAction="#goUtilisateurs" styleClass="sidebar-btn" maxWidth="Infinity"/>

            <Region prefHeight="6"/>

            <!-- ── COMPÉTITIONS ─────────────────────────────────── -->
            <Label text="COMPÉTITIONS" styleClass="sidebar-section-label"/>
            <Button fx:id="btnEvenements" text="📅  Événements"  onAction="#goEvenements" styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnMatchs"     text="🏆  Matchs"      onAction="#goMatchs"     styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnBrackets"   text="🧩  Brackets"    onAction="#goBrackets"   styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnEquipes"    text="👥  Équipes"     onAction="#goEquipe"     styleClass="sidebar-btn" maxWidth="Infinity"/>

            <Region prefHeight="6"/>

            <!-- ── CONTENU ──────────────────────────────────────── -->
            <Label text="CONTENU" styleClass="sidebar-section-label"/>
            <Button fx:id="btnPlayList"  text="🎓  Coaching"  onAction="#goPlayList"  styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnCoaching"  text="🎬  Vidéos"    onAction="#goCoaching"  styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnSocial"    text="🌐  Social"    onAction="#goSocial"    styleClass="sidebar-btn" maxWidth="Infinity"/>

            <!-- Sous-items Social (indentés) -->
            <HBox fx:id="subSocial" style="-fx-padding:0 0 0 12;" spacing="0">
                <VBox spacing="1" HBox.hgrow="ALWAYS">
                    <Button fx:id="btnAdminPosts"         text="  📝  Posts"         onAction="#goAdminPosts"         styleClass="sidebar-sub-btn" maxWidth="Infinity"/>
                    <Button fx:id="btnAdminCommentaires"  text="  💬  Commentaires"  onAction="#goAdminCommentaires"  styleClass="sidebar-sub-btn" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <Button fx:id="btnStreams" text="📡  Streams" onAction="#goStreams" styleClass="sidebar-btn" maxWidth="Infinity"/>

            <Region prefHeight="6"/>

            <!-- ── FINANCE ──────────────────────────────────────── -->
            <Label text="FINANCE" styleClass="sidebar-section-label"/>
            <Button fx:id="btnDonations"    text="💰  Donations"          onAction="#goDonations"   styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnAbonnements"  text="💳  Abonnements"        onAction="#goAbonnement"  styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnInscriptions" text="👤  Inscriptions"       onAction="#goInscriptions" styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnHistorique"   text="🧾  Historique paiement" onAction="#goHistorique"  styleClass="sidebar-btn" maxWidth="Infinity"/>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-background-color:rgba(139,92,246,0.15);"/>
            <Region prefHeight="4"/>

            <!-- Déconnexion -->
            <Button text="🚪  Déconnexion" onAction="#logout"
                    styleClass="sidebar-logout-btn" maxWidth="Infinity"/>

        </VBox>
    </left>

    <!-- ══ CONTENU ═════════════════════════════════════════════════ -->
    <center>
        <BorderPane fx:id="contentArea" style="-fx-background-color:#0a0a0f;"/>
    </center>

</BorderPane>
