<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gamilha.controllers.admin.AdminStreamPredictionController"
      stylesheets="@../../css/style.css"
      spacing="0" style="-fx-background-color:#0d1117;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:#111827;-fx-border-color:transparent transparent #1f2937 transparent;-fx-border-width:0 0 1 0;-fx-padding:20 28;">
        <VBox spacing="3">
            <Label text="🤖 Prévision IA — Activité des Streams"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#f9fafb;"/>
            <Label text="Analyse globale de tous les streams de la plateforme · 6 derniers mois"
                   style="-fx-font-size:12px;-fx-text-fill:#6b7280;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="← Retour Streams" onAction="#onBackToStreams"
                style="-fx-background-color:#0f172a;-fx-text-fill:#cbd5e1;-fx-border-color:#334155;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:8 14;-fx-cursor:hand;"/>
        <Button text="↺ Actualiser" onAction="#onRefresh"
                style="-fx-background-color:#1f2937;-fx-text-fill:#9ca3af;-fx-border-color:#374151;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:8 16;-fx-cursor:hand;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent;-fx-border-color:transparent;">
        <VBox spacing="20">
            <padding><Insets topRightBottomLeft="24"/></padding>

            <!-- KPI Cards -->
            <HBox spacing="16">

                <!-- Total streams -->
                <VBox HBox.hgrow="ALWAYS" spacing="6"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:20;">
                    <Label text="📡 TOTAL STREAMS" style="-fx-text-fill:#6b7280;-fx-font-size:11px;-fx-font-weight:bold;"/>
                    <Label fx:id="lblTotalStreams" text="—"
                           style="-fx-font-size:36px;-fx-font-weight:bold;-fx-text-fill:#f9fafb;"/>
                    <Label fx:id="lblTotalSub" text="sur la plateforme"
                           style="-fx-font-size:12px;-fx-text-fill:#4b5563;"/>
                </VBox>

                <!-- Prévision mois prochain -->
                <VBox HBox.hgrow="ALWAYS" spacing="6"
                      style="-fx-background-color:#1e1040;-fx-border-color:#7c3aed;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:20;-fx-effect:dropshadow(gaussian,rgba(139,92,246,0.25),16,0,0,4);">
                    <Label text="🎯 PRÉVISION MOIS PROCHAIN" style="-fx-text-fill:#a78bfa;-fx-font-size:11px;-fx-font-weight:bold;"/>
                    <Label fx:id="lblPrediction" text="—"
                           style="-fx-font-size:36px;-fx-font-weight:bold;-fx-text-fill:#c4b5fd;"/>
                    <Label fx:id="lblMoisCible" text="—"
                           style="-fx-font-size:12px;-fx-text-fill:#7c3aed;"/>
                </VBox>

                <!-- Moyenne mensuelle -->
                <VBox HBox.hgrow="ALWAYS" spacing="6"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:20;">
                    <Label text="📊 MOYENNE / MOIS" style="-fx-text-fill:#6b7280;-fx-font-size:11px;-fx-font-weight:bold;"/>
                    <Label fx:id="lblMoyenne" text="—"
                           style="-fx-font-size:36px;-fx-font-weight:bold;-fx-text-fill:#f9fafb;"/>
                    <Label text="streams en moyenne" style="-fx-font-size:12px;-fx-text-fill:#4b5563;"/>
                </VBox>

                <!-- Tendance -->
                <VBox HBox.hgrow="ALWAYS" spacing="6"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:20;">
                    <Label text="📈 TENDANCE" style="-fx-text-fill:#6b7280;-fx-font-size:11px;-fx-font-weight:bold;"/>
                    <Label fx:id="lblTendance" text="—"
                           style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:#4ade80;"/>
                    <Label text="6 derniers mois" style="-fx-font-size:12px;-fx-text-fill:#4b5563;"/>
                </VBox>

            </HBox>

            <!-- Graphique + Top streamers -->
            <HBox spacing="16">

                <!-- Bar Chart -->
                <VBox HBox.hgrow="ALWAYS" spacing="10"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:20;">
                    <Label text="Streams par mois (barre violette ★ = prévision)"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#e5e7eb;"/>
                    <BarChart fx:id="barChart" prefHeight="280" animated="false" legendVisible="false"
                              style="-fx-background-color:transparent;-fx-border-color:transparent;">
                        <xAxis><CategoryAxis fx:id="xAxis"/></xAxis>
                        <yAxis><NumberAxis fx:id="yAxis" minorTickCount="1"/></yAxis>
                    </BarChart>
                </VBox>

                <!-- Top 5 streamers -->
                <VBox prefWidth="260" spacing="10"
                      style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:20;">
                    <Label text="🏆 Top Streamers"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#e5e7eb;"/>
                    <VBox fx:id="topStreamersBox" spacing="8"/>
                </VBox>

            </HBox>

            <!-- Message analyse IA -->
            <VBox spacing="10"
                  style="-fx-background-color:#111827;-fx-border-color:#1f2937;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:20;">
                <Label text="🔮 Analyse automatique"
                       style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#e5e7eb;"/>
                <Label fx:id="lblMessage" text="Chargement…" wrapText="true"
                       style="-fx-text-fill:#9ca3af;-fx-font-size:13px;-fx-line-spacing:2;"/>
            </VBox>

            <!-- Conseil IA (visible si OpenRouter configuré) -->
            <VBox fx:id="aiBox" visible="false" managed="false" spacing="10"
                  style="-fx-background-color:#1e1040;-fx-border-color:#7c3aed;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:20;">
                <Label text="🤖 Conseil IA (OpenRouter)"
                       style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#a78bfa;"/>
                <Label fx:id="lblAiMessage" text="" wrapText="true"
                       style="-fx-text-fill:#c4b5fd;-fx-font-size:13px;"/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
