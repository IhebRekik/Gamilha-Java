<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controllers.NavBarAdminController"
            style="-fx-background-color:#111827;">

    <!-- ══ SIDEBAR ════════════════════════════════════════════════════════ -->
    <left>
        <VBox prefWidth="245" spacing="3"
              style="-fx-background-color:#0d0d1a;
                     -fx-border-color:#1f1f3a;-fx-border-width:0 1 0 0;">
            <padding><Insets top="22" right="10" bottom="18" left="10"/></padding>

            <!-- LOGO -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <HBox.margin><Insets bottom="14"/></HBox.margin>
                <Label text="🎮" style="-fx-font-size:26;"/>
                <VBox spacing="1">
                    <Label text="Gamilha"
                           style="-fx-text-fill:#c84cff;-fx-font-size:17;-fx-font-weight:bold;"/>
                    <Label text="Admin Panel"
                           style="-fx-text-fill:#6b7280;-fx-font-size:10;"/>
                </VBox>
            </HBox>

            <Separator style="-fx-background-color:#1f1f3a;"/>

            <!-- SECTION : Principal -->
            <Label text="PRINCIPAL"
                   style="-fx-text-fill:#4b5563;-fx-font-size:10;-fx-font-weight:bold;">
                <VBox.margin><Insets top="8" left="4"/></VBox.margin>
            </Label>
            <Button fx:id="btnDashboard"    text="📊  Dashboard"    maxWidth="Infinity"
                    onAction="#goDashboard"    style="-fx-text-fill:white;-fx-background-color:transparent;-fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;"/>
            <Button fx:id="btnUtilisateurs" text="👥  Utilisateurs" maxWidth="Infinity"
                    onAction="#goUtilisateurs" style="-fx-text-fill:white;-fx-background-color:transparent;-fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;"/>

            <!-- SECTION : Compétitions -->
            <Label text="COMPÉTITIONS"
                   style="-fx-text-fill:#4b5563;-fx-font-size:10;-fx-font-weight:bold;">
                <VBox.margin><Insets top="8" left="4"/></VBox.margin>
            </Label>
            <Button fx:id="btnEvenements" text="📅  Événements"  maxWidth="Infinity"
                    onAction="#goEvenements" style="-fx-text-fill:white;-fx-background-color:transparent;-fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;"/>
            <Button fx:id="btnMatchs"     text="🏆  Matchs"      maxWidth="Infinity"
                    onAction="#goMatchs"     style="-fx-text-fill:white;-fx-background-color:transparent;-fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;"/>
            <Button fx:id="btnBrackets"   text="🧩  Brackets"    maxWidth="Infinity"
                    onAction="#goBrackets"   style="-fx-text-fill:white;-fx-background-color:transparent;-fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;"/>
            <Button fx:id="btnEquipes"    text="👨‍👩‍👧  Équipes"    maxWidth="Infinity"
                    onAction="#goEquipe"    style="-fx-text-fill:white;-fx-background-color:transparent;-fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;"/>

            <!-- SECTION : Contenu -->
            <Label text="CONTENU"
                   style="-fx-text-fill:#4b5563;-fx-font-size:10;-fx-font-weight:bold;">
                <VBox.margin><Insets top="8" left="4"/></VBox.margin>
            </Label>
            <Button fx:id="btnCoaching" text="🎓  Coaching" maxWidth="Infinity"
                    onAction="#goCoaching" style="-fx-text-fill:white;-fx-background-color:transparent;-fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;"/>

            <!-- ██ SOCIAL ██ -->
            <Button fx:id="btnSocial"
                    text="🌐  Social"
                    maxWidth="Infinity" onAction="#goSocial"
                    style="-fx-text-fill:#c84cff;-fx-background-color:#1a0a2e;
                           -fx-font-size:12;-fx-font-weight:bold;-fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT;-fx-padding:7 12;
                           -fx-background-radius:8;">
                <VBox.margin><Insets top="2" bottom="2"/></VBox.margin>
            </Button>

            <!-- Sous-menu Social -->
            <VBox spacing="0" style="-fx-padding:0 0 0 16;">
                <Button fx:id="btnAdminPosts" text="📝  Posts"
                        maxWidth="Infinity" onAction="#goAdminPosts"
                        style="-fx-text-fill:#9ca3af;-fx-background-color:transparent;
                               -fx-font-size:11;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:5 10;"/>
                <Button fx:id="btnAdminCommentaires" text="💬  Commentaires"
                        maxWidth="Infinity" onAction="#goAdminCommentaires"
                        style="-fx-text-fill:#9ca3af;-fx-background-color:transparent;
                               -fx-font-size:11;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:5 10;"/>
            </VBox>

            <Button fx:id="btnStreams" text="📡  Streams" maxWidth="Infinity"
                    onAction="#goStreams" style="-fx-text-fill:white;-fx-background-color:transparent;-fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;"/>

            <!-- SECTION : Finance -->
            <Label text="FINANCE"
                   style="-fx-text-fill:#4b5563;-fx-font-size:10;-fx-font-weight:bold;">
                <VBox.margin><Insets top="8" left="4"/></VBox.margin>
            </Label>
            <Button fx:id="btnDonations"    text="💰  Donations"         maxWidth="Infinity"
                    onAction="#goDonations"    style="-fx-text-fill:white;-fx-background-color:transparent;-fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;"/>
            <Button fx:id="btnAbonnements"  text="💳  Abonnements"       maxWidth="Infinity"
                    onAction="#goAbonnement"   style="-fx-text-fill:white;-fx-background-color:transparent;-fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;"/>
            <Button fx:id="btnInscriptions" text="👤  Inscriptions"      maxWidth="Infinity"
                    onAction="#goInscriptions" style="-fx-text-fill:white;-fx-background-color:transparent;-fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;"/>
            <Button fx:id="btnHistorique"   text="🧾  Historique Paiement" maxWidth="Infinity"
                    onAction="#goHistorique"   style="-fx-text-fill:white;-fx-background-color:transparent;-fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator style="-fx-background-color:#1f1f3a;"/>
            <Button text="🚪  Déconnexion" maxWidth="Infinity" onAction="#logout"
                    style="-fx-text-fill:#ff4d4d;-fx-background-color:transparent;
                           -fx-font-size:12;-fx-cursor:hand;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;">
                <VBox.margin><Insets top="4"/></VBox.margin>
            </Button>
        </VBox>
    </left>

    <!-- ══ TOP BAR ════════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_RIGHT"
              style="-fx-background-color:#0d0d1a;-fx-padding:11 20;
                     -fx-border-color:#1f1f3a;-fx-border-width:0 0 1 0;">
            <Label fx:id="welcomeLabel" style="-fx-text-fill:white;-fx-font-size:13;"/>
        </HBox>
    </top>

    <!-- ══ CONTENU ════════════════════════════════════════════════════════ -->
    <center>
        <BorderPane fx:id="contentArea" style="-fx-background-color:#111827;"/>
    </center>

</BorderPane>
