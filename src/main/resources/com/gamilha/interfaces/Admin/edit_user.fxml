<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.shape.Rectangle?>

<ScrollPane fitToWidth="true"
            fx:controller="com.gamilha.controllers.EditUserController"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color:#1a1e2e;-fx-background:transparent;">

<VBox spacing="22" alignment="TOP_CENTER"
      style="-fx-background-color:#1a1e2e;">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <!-- Back -->
    <HBox maxWidth="900" alignment="CENTER_LEFT">
        <Button text="← Retour à la liste" onAction="#cancel"
                style="-fx-font-size:14px;-fx-background-color:transparent;-fx-text-fill:#c084fc;
                       -fx-background-radius:8;-fx-padding:8 16;-fx-cursor:hand;"/>
    </HBox>

    <!-- Title -->
    <Label text="✏ Modifier l'utilisateur"
           style="-fx-font-size:24px;-fx-font-weight:bold;-fx-text-fill:white;"/>

    <!-- Error / Success -->
    <Label fx:id="errorLabel" wrapText="true" maxWidth="860"
           style="-fx-text-fill:#fca5a5;-fx-background-color:#2d1111;-fx-padding:10;-fx-background-radius:8;"
           visible="false" managed="false"/>
    <Label fx:id="successLabel" wrapText="true" maxWidth="860"
           style="-fx-text-fill:#86efac;-fx-background-color:#0f2d18;-fx-padding:10;-fx-background-radius:8;"
           visible="false" managed="false"/>

    <!-- Main Card -->
    <VBox maxWidth="900" spacing="20"
          style="-fx-background-color:#0d1117;-fx-background-radius:14;-fx-padding:30;
                 -fx-border-color:#1e293b;-fx-border-radius:14;">

        <GridPane hgap="25" vgap="16">
            <columnConstraints>
                <ColumnConstraints prefWidth="200"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Avatar -->
            <Label text="Photo de profil" style="-fx-text-fill:#94a3b8;"/>
            <HBox spacing="16" alignment="CENTER_LEFT" GridPane.columnIndex="1">
                <ImageView fx:id="avatarPreview" fitWidth="90" fitHeight="90" preserveRatio="true"/>
                <VBox spacing="8">
                    <Button text="📷 Choisir image" onAction="#chooseAvatar"
                            style="-fx-background-color:#7c3aed;-fx-text-fill:white;-fx-background-radius:8;-fx-padding:8 16;-fx-cursor:hand;"/>
                    <Label fx:id="avatarPathLabel" text="aucune image"
                           style="-fx-text-fill:#475569;-fx-font-size:12px;"/>
                </VBox>
            </HBox>

            <!-- Name -->
            <Label text="Nom complet" GridPane.rowIndex="1" style="-fx-text-fill:#94a3b8;"/>
            <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                       style="-fx-background-color:#1a1e2e;-fx-text-fill:white;-fx-border-color:#374151;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:10;"/>

            <!-- Email -->
            <Label text="Adresse email" GridPane.rowIndex="2" style="-fx-text-fill:#94a3b8;"/>
            <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="2"
                       style="-fx-background-color:#1a1e2e;-fx-text-fill:white;-fx-border-color:#374151;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:10;"/>
        </GridPane>

        <Separator style="-fx-border-color:#1e293b;"/>

        <!-- Password Section -->
        <Label text="🔒 Changer le mot de passe"
               style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#a78bfa;"/>

        <GridPane hgap="25" vgap="14">
            <columnConstraints>
                <ColumnConstraints prefWidth="200"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Ancien mot de passe" style="-fx-text-fill:#94a3b8;"/>
            <PasswordField fx:id="oldPasswordField" GridPane.columnIndex="1"
                           promptText="Entrez votre ancien mot de passe"
                           style="-fx-background-color:#1a1e2e;-fx-text-fill:white;-fx-border-color:#374151;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:10;"/>

            <Label text="Nouveau mot de passe" GridPane.rowIndex="1" style="-fx-text-fill:#94a3b8;"/>
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="6">
                <PasswordField fx:id="passwordField"
                               promptText="Laisser vide pour ne pas changer"
                               style="-fx-background-color:#1a1e2e;-fx-text-fill:white;-fx-border-color:#374151;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:10;"/>
                <Label fx:id="strengthLabel" style="-fx-font-size:12px;" visible="false" managed="false"/>
                <Label text="Min 8 car., 1 majuscule, 1 chiffre, 1 symbole"
                       style="-fx-text-fill:#475569;-fx-font-size:11px;"/>
            </VBox>

            <Label text="Confirmer le mot de passe" GridPane.rowIndex="2" style="-fx-text-fill:#94a3b8;"/>
            <PasswordField fx:id="confirmPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="2"
                           promptText="Confirmez le nouveau mot de passe"
                           style="-fx-background-color:#1a1e2e;-fx-text-fill:white;-fx-border-color:#374151;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:10;"/>
        </GridPane>

        <Separator style="-fx-border-color:#1e293b;"/>

        <!-- Admin section -->
        <Label text="⚙ Administration"
               style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#a78bfa;"/>

        <GridPane hgap="25" vgap="14">
            <columnConstraints>
                <ColumnConstraints prefWidth="200"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Rôles" style="-fx-text-fill:#94a3b8;"/>
            <HBox GridPane.columnIndex="1" spacing="20" alignment="CENTER_LEFT">
                <CheckBox fx:id="adminCheckBox"     text="Administrateur" style="-fx-text-fill:white;"/>
                <CheckBox fx:id="moderatorCheckBox" text="Modérateur"     style="-fx-text-fill:white;"/>
                <CheckBox fx:id="coachCheckBox"     text="Coach"          style="-fx-text-fill:white;"/>
            </HBox>

            <Label text="Compte actif" GridPane.rowIndex="1" style="-fx-text-fill:#94a3b8;"/>
            <HBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="10" alignment="CENTER_LEFT">
                <CheckBox fx:id="activeCheckBox" style="-fx-text-fill:white;"/>
                <Label text="Désactiver empêche la connexion" style="-fx-text-fill:#64748b;-fx-font-size:12px;"/>
            </HBox>

            <Label text="Signalements" GridPane.rowIndex="2" style="-fx-text-fill:#94a3b8;"/>
            <HBox GridPane.columnIndex="1" GridPane.rowIndex="2" spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="reportsField" prefWidth="80"
                           style="-fx-background-color:#1a1e2e;-fx-text-fill:white;-fx-border-color:#374151;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:8;"/>
                <Label text="Nombre de signalements reçus" style="-fx-text-fill:#64748b;-fx-font-size:12px;"/>
            </HBox>
        </GridPane>
    </VBox>

    <!-- Buttons -->
    <HBox spacing="15" alignment="CENTER_RIGHT" maxWidth="900">
        <Button text="✕ Annuler" onAction="#cancel"
                style="-fx-background-color:#374151;-fx-text-fill:white;-fx-background-radius:8;-fx-padding:10 24;-fx-cursor:hand;"/>
        <Button text="💾 Enregistrer" onAction="#updateUser"
                style="-fx-background-color:#7c3aed;-fx-text-fill:white;-fx-background-radius:8;
                       -fx-padding:10 24;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </HBox>

</VBox>
</ScrollPane>
