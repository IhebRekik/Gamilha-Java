<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color:#0a0f1e;-fx-background:#0a0f1e;-fx-border-color:transparent;"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.gamilha.controllers.coaching.PlaylistController">

    <VBox spacing="22" prefWidth="760"
          style="-fx-background-color:#0a0f1e;">
        <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

        <!-- TITRE FORMULAIRE -->
        <Label fx:id="lblFormTitle"
               text="➕ Nouvelle Playlist"
               style="-fx-text-fill:#c084fc;-fx-font-size:22;-fx-font-weight:bold;"/>

        <!-- IMAGE D'EN-TÊTE : preview + bouton import -->
        <VBox spacing="10"
              style="-fx-background-color:#1e293b;-fx-background-radius:10;-fx-padding:16;
                     -fx-border-color:#334155;-fx-border-radius:10;-fx-border-width:1;">

            <Label text="🖼️ Image de la playlist"
                   style="-fx-text-fill:#94a3b8;-fx-font-size:13;-fx-font-weight:bold;"/>

            <!-- Prévisualisation -->
            <ImageView fx:id="imgPreview"
                       fitWidth="280" fitHeight="150"
                       preserveRatio="true"
                       visible="false" managed="false"
                       style="-fx-background-radius:8;"/>

            <HBox spacing="14" alignment="CENTER_LEFT">
                <Button fx:id="btnChooseImage"
                        text="📁 Choisir une image"
                        onAction="#handleChooseImage"
                        style="-fx-background-color:#7c3aed;-fx-text-fill:white;
                               -fx-font-weight:bold;-fx-background-radius:7;-fx-padding:9 18;"/>
                <Label fx:id="lblImagePath"
                       text="Aucun fichier sélectionné"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
            </HBox>
            <Label text="Formats acceptés : PNG, JPG, JPEG, GIF, WEBP"
                   style="-fx-text-fill:#475569;-fx-font-size:11;"/>
        </VBox>

        <!-- TITRE -->
        <VBox spacing="7">
            <Label text="Titre *" style="-fx-text-fill:#94a3b8;-fx-font-size:13;-fx-font-weight:bold;"/>
            <TextField fx:id="txtTitle"
                       promptText="Titre de la playlist"
                       style="-fx-background-color:#1e293b;-fx-text-fill:white;
                              -fx-prompt-text-fill:#475569;-fx-background-radius:7;-fx-padding:11;
                              -fx-border-color:#334155;-fx-border-radius:7;-fx-border-width:1;"/>
        </VBox>

        <!-- DESCRIPTION -->
        <VBox spacing="7">
            <Label text="Description" style="-fx-text-fill:#94a3b8;-fx-font-size:13;-fx-font-weight:bold;"/>
            <TextArea fx:id="txtDescription"
                      promptText="Décrivez le contenu de cette playlist..."
                      prefRowCount="4" wrapText="true"
                      style="-fx-background-color:#1e293b;-fx-text-fill:white;
                             -fx-prompt-text-fill:#475569;-fx-background-radius:7;-fx-padding:10;
                             -fx-border-color:#334155;-fx-border-radius:7;-fx-border-width:1;"/>
        </VBox>

        <!-- NIVEAU + CATÉGORIE -->
        <HBox spacing="20">
            <VBox spacing="7" HBox.hgrow="ALWAYS">
                <Label text="Niveau" style="-fx-text-fill:#94a3b8;-fx-font-size:13;-fx-font-weight:bold;"/>
                <ComboBox fx:id="cmbNiveau" prefWidth="2000"
                          style="-fx-background-color:#1e293b;-fx-text-fill:white;-fx-background-radius:7;-fx-padding:4;"/>
            </VBox>
            <VBox spacing="7" HBox.hgrow="ALWAYS">
                <Label text="Catégorie" style="-fx-text-fill:#94a3b8;-fx-font-size:13;-fx-font-weight:bold;"/>
                <TextField fx:id="txtCategorie"
                           promptText="Ex : FPS, MOBA, RPG…"
                           style="-fx-background-color:#1e293b;-fx-text-fill:white;
                                  -fx-prompt-text-fill:#475569;-fx-background-radius:7;-fx-padding:11;
                                  -fx-border-color:#334155;-fx-border-radius:7;-fx-border-width:1;"/>
            </VBox>
        </HBox>

        <!-- ERREUR -->
        <Label fx:id="lblError" text=""
               style="-fx-text-fill:#f87171;-fx-font-size:13;"/>

        <!-- BOUTONS -->
        <HBox spacing="14" alignment="CENTER_RIGHT">
            <Button fx:id="btnCancel" text="✖ Annuler"
                    style="-fx-background-color:#374151;-fx-text-fill:white;
                           -fx-background-radius:8;-fx-padding:11 26;-fx-font-size:13;"/>
            <Button fx:id="btnSave" text="💾 Enregistrer"
                    style="-fx-background-color:linear-gradient(to right,#7c3aed,#4c1d95);
                           -fx-text-fill:white;-fx-font-weight:bold;
                           -fx-background-radius:8;-fx-padding:11 26;-fx-font-size:13;"/>
        </HBox>

    </VBox>
</ScrollPane>
