<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controllers.UserMainController"
            prefWidth="1060" prefHeight="720"
            style="-fx-background-color:#13131f;">

    <!-- ══ SIDEBAR ════════════════════════════════════════════════════════ -->
    <left>
        <VBox prefWidth="210" spacing="4"
              style="-fx-background-color:#1a1a2e;-fx-border-color:#3a3a5c;-fx-border-width:0 1 0 0;">
            <padding><Insets top="24" right="12" bottom="20" left="12"/></padding>

            <!-- Logo -->
            <VBox alignment="CENTER" spacing="4">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
                <Label text="🎮" style="-fx-font-size:36;"/>
                <Label text="Gamilha"
                       style="-fx-font-size:19;-fx-font-weight:bold;-fx-text-fill:#58a6ff;"/>
            </VBox>

            <!-- Profil utilisateur connecté -->
            <VBox alignment="CENTER" spacing="6"
                  style="-fx-background-color:#252535;-fx-background-radius:10;">
                <padding><Insets top="12" right="8" bottom="12" left="8"/></padding>
                <VBox.margin><Insets bottom="8"/></VBox.margin>
                <ImageView fx:id="userAvatar" fitWidth="44" fitHeight="44"/>
                <Label fx:id="userNameLabel" text="Utilisateur"
                       style="-fx-font-weight:bold;-fx-text-fill:#e6edf3;-fx-font-size:13;"/>
                <Label fx:id="userEmailLabel" text=""
                       style="-fx-text-fill:#8b949e;-fx-font-size:10;" wrapText="true"
                       maxWidth="170"/>
            </VBox>

            <Separator style="-fx-background-color:#3a3a5c;"/>

            <!-- Menu -->
            <VBox spacing="4">
                <VBox.margin><Insets top="10"/></VBox.margin>
                <Button fx:id="btnPosts" text="🏠  Fil d'actualité"
                        maxWidth="Infinity" onAction="#showFeed"
                        style="-fx-background-color:#3b82f6;-fx-text-fill:white;
                               -fx-background-radius:8;-fx-alignment:CENTER_LEFT;
                               -fx-padding:10 14;-fx-font-size:13;-fx-cursor:hand;"/>
                <Button fx:id="btnMesPosts" text="📝  Mes Posts"
                        maxWidth="Infinity" onAction="#showMesPosts"
                        style="-fx-background-color:transparent;-fx-text-fill:#c9d1d9;
                               -fx-background-radius:8;-fx-alignment:CENTER_LEFT;
                               -fx-padding:10 14;-fx-font-size:13;-fx-cursor:hand;"/>
                <Button fx:id="btnMesCommentaires" text="💬  Mes Commentaires"
                        maxWidth="Infinity" onAction="#showMesCommentaires"
                        style="-fx-background-color:transparent;-fx-text-fill:#c9d1d9;
                               -fx-background-radius:8;-fx-alignment:CENTER_LEFT;
                               -fx-padding:10 14;-fx-font-size:13;-fx-cursor:hand;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator style="-fx-background-color:#3a3a5c;"/>
            <Label text="Gamilha © 2025" alignment="CENTER" maxWidth="Infinity"
                   style="-fx-text-fill:#6e7681;-fx-font-size:11;">
                <VBox.margin><Insets top="8"/></VBox.margin>
            </Label>
        </VBox>
    </left>

    <!-- ══ ZONE CENTRALE ══════════════════════════════════════════════════ -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color:#13131f;"/>
    </center>

</BorderPane>
