<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controller.StreamFormController"
            stylesheets="@../css/style.css"
            prefWidth="1280" prefHeight="800">

    <!-- ══ NAVBAR ══ -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="navbar">
                <padding><Insets topRightBottomLeft="14"/></padding>
                <Label text="🎮 GAMILHA" styleClass="brand"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="📡 Streams"  onAction="#onCancel" styleClass="btn-secondary"/>
                <Button text="← Annuler"   onAction="#onCancel" styleClass="btn-secondary"/>
            </HBox>

            <!-- Fil d'ariane -->
            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="page-header">
                <padding><Insets top="14" right="24" bottom="10" left="24"/></padding>
                <Label fx:id="pageTitle" text="🔴 Lancer un nouveau Stream" styleClass="page-title"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-dark">
            <VBox spacing="18" maxWidth="700" styleClass="form-wrap">
                <padding><Insets top="20" right="40" bottom="30" left="40"/></padding>

                <!-- ─ Informations ─ -->
                <VBox spacing="10" styleClass="form-card">
                    <Label text="INFORMATIONS DU STREAM" styleClass="section-lbl"/>

                    <VBox spacing="3">
                        <Label text="Titre *" styleClass="field-lbl"/>
                        <TextField fx:id="titleField"
                                   promptText="Ex : CS2 Ranked — Road to Global"
                                   styleClass="field-dark"/>
                        <Label fx:id="errTitle" styleClass="err-lbl" visible="false" managed="false"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Description (max 2000 car.)" styleClass="field-lbl"/>
                        <TextArea fx:id="descArea" prefRowCount="3" wrapText="true"
                                  promptText="Décrivez votre stream…"
                                  styleClass="area-dark"/>
                        <Label fx:id="errDesc" styleClass="err-lbl" visible="false" managed="false"/>
                    </VBox>
                </VBox>

                <!-- ─ Jeu ─ -->
                <VBox spacing="10" styleClass="form-card">
                    <Label text="JEU *" styleClass="section-lbl"/>
                    <VBox spacing="3">
                        <Label text="Sélectionner un jeu" styleClass="field-lbl"/>
                        <ComboBox fx:id="gameCombo" prefWidth="300" styleClass="combo-dark"/>
                        <Label fx:id="errGame" styleClass="err-lbl" visible="false" managed="false"/>
                    </VBox>
                </VBox>

                <!-- ─ Miniature — URL obligatoire avec validation ─ -->
                <VBox spacing="10" styleClass="form-card">
                    <Label text="MINIATURE DU STREAM *" styleClass="section-lbl"/>
                    <VBox spacing="3">
                        <Label text="URL de l'image *" styleClass="field-lbl"/>
                        <TextField fx:id="thumbField"
                                   promptText="https://example.com/image.jpg"
                                   styleClass="field-dark"/>
                        <!-- Label d'erreur thumbnail -->
                        <Label fx:id="errThumb" styleClass="err-lbl" visible="false" managed="false"/>
                        <Label text="Format accepté : .jpg .png .webp .gif"
                               styleClass="field-hint"/>
                    </VBox>
                </VBox>

                <!-- ─ Statut ─ -->
                <VBox spacing="10" styleClass="form-card">
                    <Label text="STATUT" styleClass="section-lbl"/>
                    <VBox spacing="3">
                        <Label text="État du stream" styleClass="field-lbl"/>
                        <ComboBox fx:id="statusCombo" prefWidth="200" styleClass="combo-dark"/>
                    </VBox>
                </VBox>

                <!-- ─ Champs visibles UNIQUEMENT en mode édition ─ -->
                <!-- editOnlyBox caché en création, visible en édition -->
                <VBox fx:id="editOnlyBox" spacing="10" styleClass="form-card"
                      visible="false" managed="false">
                    <Label text="PARAMÈTRES AVANCÉS (édition)" styleClass="section-lbl"/>

                    <VBox spacing="3">
                        <Label text="URL du stream" styleClass="field-lbl"/>
                        <TextField fx:id="urlField" promptText="https://…" styleClass="field-dark"/>
                        <Label fx:id="errUrl" styleClass="err-lbl" visible="false" managed="false"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Viewers" styleClass="field-lbl"/>
                        <Spinner fx:id="viewersSpinner" styleClass="spinner-dark"
                                 editable="true" prefWidth="160"/>
                    </VBox>
                </VBox>

                <!-- Clé de stream (mode édition) -->
                <Label fx:id="obsInfo" styleClass="obs-badge"
                       visible="false" managed="false" wrapText="true"/>

                <!-- Boutons -->
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="Annuler" onAction="#onCancel"
                            styleClass="btn-secondary" prefWidth="130"/>
                    <Button fx:id="submitBtn" text="🔴 Démarrer"
                            onAction="#onSubmit" styleClass="btn-danger" prefWidth="200"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
