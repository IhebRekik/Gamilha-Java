<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gamilha.controllers.AddUserController"
      spacing="20"
      styleClass="card">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <children>
        <Label text="➕ Nouvel Utilisateur"
               style="-fx-font-size: 24px; -fx-text-fill: white; -fx-font-weight: bold;"/>

        <GridPane hgap="15" vgap="15">
            <columnConstraints>
                <ColumnConstraints percentWidth="40"/>
                <ColumnConstraints percentWidth="60"/>
            </columnConstraints>

            <Label text="Nom complet :"
                   style="-fx-text-fill: #c4c4c4;"
                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="nameField" promptText="Entrez le nom complet"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Email :"
                   style="-fx-text-fill: #c4c4c4;"
                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="emailField" promptText="exemple@email.com"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Mot de passe :"
                   style="-fx-text-fill: #c4c4c4;"
                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <PasswordField fx:id="passwordField" promptText="Minimum 6 caractères"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Rôle :"
                   style="-fx-text-fill: #c4c4c4;"
                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <ComboBox fx:id="roleCombo" promptText="Choisir un rôle"
                      GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        </GridPane>

        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Button text="Annuler"
                    styleClass="button-danger"
                    onAction="#cancel"/>
            <Button text="Enregistrer l'utilisateur"
                    styleClass="button-primary"
                    onAction="#saveUser"/>
        </HBox>
    </children>
</VBox>