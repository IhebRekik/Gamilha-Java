<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.gamilha.controllers.DashboardController"
            style="-fx-background-color:transparent;">
    <top>
        <VBox fx:id="headerBox" spacing="0">
            <HBox spacing="10" styleClass="top-bar" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="12" right="14" bottom="12" left="14"/>
                </padding>
                <ImageView fitWidth="34" fitHeight="34" preserveRatio="true">
                    <image>
                        <Image url="@images/gamilha.png"/>
                    </image>
                </ImageView>
                <Label fx:id="titleLabel" styleClass="brand-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="subtitleLabel" styleClass="sub-title"/>
                <Button text="Logout" styleClass="logout-btn" onAction="#onLogout"/>
            </HBox>
            <HBox fx:id="topNav" spacing="8" styleClass="top-nav" visible="false" managed="false">
                <padding>
                    <Insets top="8" right="14" bottom="8" left="14"/>
                </padding>
            </HBox>
        </VBox>
    </top>
    <center>
        <HBox spacing="0" styleClass="dashboard-shell">
            <VBox fx:id="sideNav" styleClass="side-nav" prefWidth="230" spacing="8">
                <padding>
                    <Insets top="14" right="10" bottom="14" left="10"/>
                </padding>
            </VBox>
            <StackPane fx:id="pageContainer" styleClass="page-container" HBox.hgrow="ALWAYS"/>
        </HBox>
    </center>
</BorderPane>

