<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controller.UserCommentaireFormController"
            style="-fx-background-color:#0f1020;">

    <top>
        <VBox style="-fx-background-color:#09091a;
                     -fx-border-color:#2a2b4a;-fx-border-width:0 0 1 0;">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <Label text="✏  Modifier mon commentaire"
                   style="-fx-font-size:17;-fx-font-weight:bold;-fx-text-fill:#e6edf3;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="16">
            <padding><Insets top="22" right="26" bottom="22" left="26"/></padding>

            <Label text="Texte du commentaire  (5 à 500 caractères)"
                   style="-fx-text-fill:#8b949e;-fx-font-size:12;-fx-font-weight:bold;"/>

            <!-- ── TextArea dark ── -->
            <TextArea fx:id="textArea"
                      promptText="Votre commentaire…"
                      wrapText="true" prefHeight="130"
                      style="-fx-control-inner-background:#1a1a30;
                             -fx-background-color:#1a1a30;
                             -fx-text-fill:#e6edf3;
                             -fx-prompt-text-fill:#4b5563;
                             -fx-font-size:13;
                             -fx-border-color:#3a3a5c;
                             -fx-border-radius:8;
                             -fx-background-radius:8;
                             -fx-highlight-fill:#c84cff;
                             -fx-highlight-text-fill:#ffffff;"/>

            <HBox alignment="CENTER_RIGHT">
                <Label fx:id="charCountLabel" text="0 / 500"
                       style="-fx-font-size:11;-fx-text-fill:#8b949e;"/>
            </HBox>

            <Label fx:id="errorLabel" text=""
                   wrapText="true"
                   style="-fx-text-fill:#ef4444;-fx-font-size:12;"/>

            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Annuler" onAction="#onCancel"
                        style="-fx-background-color:#1f1f3a;-fx-text-fill:#c9d1d9;
                               -fx-background-radius:20;-fx-padding:9 24;-fx-cursor:hand;
                               -fx-border-color:#3a3a5c;-fx-border-radius:20;"/>
                <Button fx:id="btnSave" text="Enregistrer" onAction="#onSave"
                        style="-fx-background-color:#10b981;-fx-text-fill:white;
                               -fx-background-radius:20;-fx-padding:9 28;
                               -fx-font-weight:bold;-fx-cursor:hand;-fx-font-size:13;"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
