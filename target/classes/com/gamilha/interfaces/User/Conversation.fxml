<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controllers.Messages.ConversationController"
            fx:id="rootPane"
            style="-fx-background-color:#020617;">

    <VBox styleClass="chat-root"
          AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">

        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color:#020617; -fx-padding:14; -fx-border-color:#1e293b; -fx-border-width:0 0 1 0;">

            <Label text="💬" style="-fx-font-size:22;"/>

            <VBox spacing="2">
                <Label fx:id="titleLabel"
                       text="Conversation"
                       style="-fx-text-fill:white; -fx-font-size:18; -fx-font-weight:bold;"/>

                <Label fx:id="onlineLabel"
                       text="En ligne"
                       style="-fx-text-fill:#22c55e; -fx-font-size:11px;"/>
            </VBox>
        </HBox>

        <!-- MESSAGES -->
        <ScrollPane fx:id="messagesScrollPane"
                    fitToWidth="true"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background-color:#0f172a;">

            <VBox fx:id="messagesBox"
                  spacing="10"
                  style="-fx-padding:20; -fx-background-color:#0f172a;"/>
        </ScrollPane>

        <!-- INPUT -->
        <HBox alignment="CENTER"
              spacing="10"
              style="-fx-background-color:#020617; -fx-padding:10;">

            <Button text="😊"
                    onAction="#openEmojiPicker"
                    style="-fx-font-size:16;"/>

            <TextField fx:id="messageField"
                       promptText="Écrire un message..."
                       HBox.hgrow="ALWAYS"
                       onAction="#envoyerMessage"
                       style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-background-radius:10;"/>

            <Button text="Envoyer ➤"
                    onAction="#envoyerMessage"
                    style="-fx-background-color:#3b82f6; -fx-text-fill:white;"/>
        </HBox>

    </VBox>
</AnchorPane>
