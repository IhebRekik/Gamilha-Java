<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.web.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controllers.admin.AdminStreamShowController"
            stylesheets="@../../css/style.css"
            prefWidth="1280" prefHeight="800">
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="navbar">
                <padding><Insets topRightBottomLeft="14"/></padding>
                <Label text="🎮 GAMILHA — ADMIN" styleClass="brand"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="← Retour"     onAction="#onBack"      styleClass="btn-secondary"/>
                <Button text="✏ Modifier"   onAction="#onEdit"      styleClass="btn-warning"/>
                <Button text="💰 Donations" onAction="#onDonations" styleClass="btn-primary"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="page-header">
                <padding><Insets top="14" right="24" bottom="10" left="24"/></padding>
                <Label fx:id="lblTitle" text="" styleClass="page-title" wrapText="true"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStatus" text=""/>
            </HBox>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-dark">
            <VBox spacing="20">
                <padding><Insets topRightBottomLeft="28"/></padding>

                <!-- Thumbnail + infos -->
                <HBox spacing="22" alignment="TOP_LEFT">
                    <ImageView fx:id="imgThumb" fitWidth="460" fitHeight="260" preserveRatio="true"/>
                    <VBox spacing="12" HBox.hgrow="ALWAYS" styleClass="info-panel">
                        <padding><Insets topRightBottomLeft="20"/></padding>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="lblGame"    text="" styleClass="badge-game"/>
                            <Label fx:id="lblViewers" text="" styleClass="badge-viewers"/>
                        </HBox>
                        <Label fx:id="lblDesc" text="" styleClass="show-desc" wrapText="true"/>
                        <Label fx:id="lblDate" text="" styleClass="meta-lbl"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="🔗" style="-fx-font-size:13px;"/>
                            <Hyperlink fx:id="lnkUrl" text="" styleClass="link-style"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Player api.video (admin voit aussi) -->
                <VBox fx:id="playerBox" visible="false" managed="false">
                    <WebView fx:id="webPlayer" prefWidth="1180" prefHeight="560"/>
                </VBox>
                <VBox fx:id="offlineBox" alignment="CENTER" spacing="12" prefHeight="200" visible="true" managed="true"
                      style="-fx-background-color:#0c0c1a;-fx-border-color:#1f2937;-fx-border-radius:10;-fx-background-radius:10;">
                    <Label text="📷 Live stream offline" style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#94a3b8;"/>
                    <Label text="Le streamer n'a pas encore démarré OBS." style="-fx-text-fill:#475569;-fx-font-size:13px;"/>
                </VBox>

                <!-- Bloc OBS complet — admin voit toujours tout -->
                <VBox fx:id="obsBox" spacing="14"
                      style="-fx-background-color:#0c1a2e;-fx-border-color:#1d4ed8;-fx-border-radius:10;-fx-background-radius:10;"
                      visible="true" managed="true">
                    <padding><Insets topRightBottomLeft="20"/></padding>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="⚙" style="-fx-font-size:20px;"/>
                        <Label text="Informations techniques OBS / api.video"
                               style="-fx-text-fill:#60a5fa;-fx-font-size:14px;-fx-font-weight:bold;"/>
                        <Label text="(Visible admin uniquement)"
                               style="-fx-text-fill:#374151;-fx-font-size:11px;-fx-font-style:italic;"/>
                    </HBox>
                    <Separator style="-fx-background-color:#1d4ed8;"/>

                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-background-color:#0f1a2e;-fx-border-color:#1e3a5f;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:10 14;">
                        <Label text="SERVEUR :" style="-fx-text-fill:#60a5fa;-fx-font-size:11px;-fx-font-weight:bold;" minWidth="120"/>
                        <Label fx:id="lblRtmp" text="" styleClass="obs-code" HBox.hgrow="ALWAYS" wrapText="true"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-background-color:#0f1a2e;-fx-border-color:#1e3a5f;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:10 14;">
                        <Label text="CLÉ DE FLUX :" style="-fx-text-fill:#60a5fa;-fx-font-size:11px;-fx-font-weight:bold;" minWidth="120"/>
                        <Label fx:id="lblKey" text="" styleClass="obs-code" HBox.hgrow="ALWAYS" wrapText="true"/>
                        <Button text="📋 Copier" onAction="#onCopyKey" styleClass="btn-obs-copy" minWidth="90"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-background-color:#0f1a2e;-fx-border-color:#1e3a5f;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:10 14;">
                        <Label text="API VIDEO ID :" style="-fx-text-fill:#60a5fa;-fx-font-size:11px;-fx-font-weight:bold;" minWidth="120"/>
                        <Label fx:id="lblApiId" text="" styleClass="obs-code" HBox.hgrow="ALWAYS" wrapText="true"/>
                    </HBox>
                </VBox>

                <!-- Donations -->
                <VBox spacing="10" styleClass="section-box">
                    <padding><Insets topRightBottomLeft="16"/></padding>
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="📋 Donations" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblTotal" text="" styleClass="total-badge"/>
                    </HBox>
                    <FlowPane fx:id="donGrid" hgap="12" vgap="12">
                        <padding><Insets top="4" bottom="4"/></padding>
                    </FlowPane>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
    <bottom>
        <HBox alignment="CENTER" styleClass="footer">
            <padding><Insets topRightBottomLeft="10"/></padding>
            <Label text="Gamilha Admin" styleClass="footer-text"/>
        </HBox>
    </bottom>
</BorderPane>
