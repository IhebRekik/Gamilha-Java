<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="580" prefWidth="700"
            style="-fx-background-color: #0d1117;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controllers.RegisterController">

    <VBox alignment="CENTER" layoutX="170.0" layoutY="30.0" prefWidth="360" spacing="15"
          style="-fx-background-color: #1a1e2e; -fx-background-radius: 16; -fx-padding: 35;">

        <HBox alignment="CENTER" spacing="10">
            <StackPane styleClass="logo-badge">
                <ImageView styleClass="logo" fitWidth="46" fitHeight="46" preserveRatio="true" smooth="true">
                    <image>
                        <Image url="@../images/logo.jpg"/>
                    </image>
                </ImageView>
            </StackPane>
            <Label text="Gamilha" styleClass="brand-title"/>
        </HBox>

        <Label text="Créer un compte"
               style="-fx-font-size: 16px; -fx-text-fill: #94a3b8;"/>

        <Separator/>

        <Label text="Nom complet" style="-fx-text-fill: #c4c4c4;"/>
        <TextField fx:id="nameField" promptText="Votre nom"/>

        <Label text="Email" style="-fx-text-fill: #c4c4c4;"/>
        <TextField fx:id="emailField" promptText="exemple@email.com"/>

        <!-- Avatar (optionnel) -->
        <Label text="Photo de profil (optionnel)" style="-fx-text-fill: #c4c4c4;"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="Choisir une image" onAction="#chooseAvatar" styleClass="button-primary"/>
            <Label fx:id="avatarPathLabel" text="Aucune" style="-fx-text-fill: #94a3b8;"/>
        </HBox>

        <Label text="Mot de passe" style="-fx-text-fill: #c4c4c4;"/>
        <PasswordField fx:id="passwordField" promptText="Minimum 6 caractères"/>

        <Label text="Confirmer le mot de passe" style="-fx-text-fill: #c4c4c4;"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe"/>

        <Button text="✅ Créer mon compte" onAction="#handleRegister"
                styleClass="button-primary" prefWidth="300"
                style="-fx-font-size: 15px;"/>

        <Button text="← Retour à la connexion" onAction="#handleBackToLogin"
                style="-fx-font-size: 14px; -fx-background-color: transparent; -fx-text-fill: #94a3b8;"/>

    </VBox>
</AnchorPane>