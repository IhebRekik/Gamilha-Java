<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>

<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.control.ScrollPane?>
<VBox spacing="40"
      alignment="TOP_CENTER"
      style="-fx-background-color:#0f1020; -fx-padding:40;"
      prefWidth="1600"
      prefHeight="1366"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gamilha.controllers.abonnement.AbonnementController">

    <Label text="Choisissez Votre Plan"
           style="-fx-text-fill:#ff66cc;
                  -fx-font-size:32;
                  -fx-font-weight:bold;" />
    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                style="-fx-background:#0f172a;">

        <content>

            <FlowPane fx:id="containerAbonnements"
                      hgap="40"
                      vgap="40"
                      alignment="CENTER"
                      prefWrapLength="1400"
                      style="-fx-padding:40;" />

        </content>

    </ScrollPane>

</VBox>