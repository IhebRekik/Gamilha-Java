<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamilha.controllers.NavBarUserController"
            style="-fx-background-color:#111827;">

    <top>
        <VBox style="-fx-background-color:#0a0a1a;
                     -fx-border-color:#2a2a40;-fx-border-width:0 0 1 0;">

            <!-- ── BARRE PRINCIPALE ── -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-padding:6 16 6 16;-fx-spacing:3;-fx-background-color:#0a0a1a;">

                <!-- Logo -->
                <HBox spacing="7" alignment="CENTER_LEFT" style="-fx-padding:0 12 0 0;">
                    <ImageView fx:id="logoImage" fitHeight="30" fitWidth="30" preserveRatio="true"/>
                    <Label text="Gamilha"
                           style="-fx-text-fill:#c84cff;-fx-font-size:17;-fx-font-weight:bold;"/>
                </HBox>

                <!-- Boutons nav — PAS de style inline, BTN_NORMAL appliqué par le controller -->
                <Button fx:id="btnAccueil"      text="🏠 Accueil"       onAction="#goAccueil"/>
                <Button fx:id="btnEvenements"   text="📅 Événements"    onAction="#goEvenements"/>
                <Button fx:id="btnEquipes"       text="👥 Équipes"       onAction="#goEquipe"/>
                <Button fx:id="btnCoaching"     text="🎯 Coaching"      onAction="#goCoaching"/>
                <Button fx:id="btnAI"           text="🤖 Gamilha AI"    onAction="#goAI"/>
                <Button fx:id="btnReseaux"      text="🌐 Réseaux"       onAction="#goReseaux"/>
                <Button fx:id="btnStreams"       text="📡 Streams"       onAction="#goStreams"/>
                <Button fx:id="btnAbonnements"  text="💎 Abonnements"   onAction="#goAbonnement"/>

                <!-- Spacer -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Bienvenue + logout -->
                <Label fx:id="welcomeLabel"
                       style="-fx-text-fill:#c9d1d9;-fx-font-size:13;-fx-padding:0 8 0 0;"/>
                <Button text="🚪" onAction="#logout"
                        style="-fx-background-color:transparent;-fx-text-fill:#6b7280;
                               -fx-font-size:13;-fx-cursor:hand;-fx-padding:4 6;"/>
            </HBox>

            <!-- ── SOUS-MENU RÉSEAUX : caché par défaut ── -->
            <HBox fx:id="subMenuSocial"
                  alignment="CENTER_LEFT"
                  visible="false" managed="false"
                  style="-fx-padding:3 16 3 16;-fx-spacing:3;
                         -fx-background-color:#070710;
                         -fx-border-color:#1a1a30;-fx-border-width:1 0 0 0;">
                <Label text="Réseaux :"
                       style="-fx-text-fill:#374151;-fx-font-size:11;-fx-padding:0 6 0 0;"/>
                <Button fx:id="btnFilActualite"    text="🏠 Fil d'actualité"   onAction="#goFilActualite"/>
                <Button fx:id="btnMesPosts"        text="📝 Mes Posts"         onAction="#goMesPosts"/>
                <Button fx:id="btnMesCommentaires" text="💬 Mes Commentaires"  onAction="#goMesCommentaires"/>
                <Button fx:id="btnAmis"            text="👤 Amis"              onAction="#goAmis"/>
            </HBox>

        </VBox>
    </top>

    <center>
        <BorderPane fx:id="contentArea"
                    style="-fx-background-color:#111827;"/>
    </center>

</BorderPane>
